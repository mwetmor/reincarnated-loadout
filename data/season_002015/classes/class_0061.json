  "skills": [
    {
      "id": "skill_001442",
      "name": "Sovereign Seal Unbroken",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "self_buff",
      "energy_cost": 18.9,
      "cooldown_seconds": 8.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.1
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.18,
            "duration_seconds": 7.2
          }
        }
      ],
      "flavor_text": "The cold marble breathes inward, pressing close like the hush before a king's judgment falls. What the wind cannot move, the throne has already claimed."
    },
    {
      "id": "skill_001443",
      "name": "Marble Throne Edict",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 27.1,
      "cooldown_seconds": 5.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.28,
            "duration_seconds": 8.3
          }
        }
      ],
      "flavor_text": "The cold floor of the throne room groans as the Mad King's word tears through the air in a cone of crumbling pale stone. Those who survive the decree find their own fury sharpened, as if the earth itself demands recompense."
    },
    {
      "id": "skill_001444",
      "name": "Sovereign Seal Trembles",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 28.1,
      "cooldown_seconds": 6.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The marble floor cracks in branching lines as if the throne room itself refuses the king's last edict. Each fracture carries the weight of a wisdom older than the crown."
    },
    {
      "id": "skill_001445",
      "name": "Exile Writ Descends",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 24.6,
      "cooldown_seconds": 4.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 4.8,
            "stagger_seconds": 1.0
          }
        }
      ],
      "flavor_text": "A circle of condemned air collapses onto the ground where the king's seal once blessed, tearing outward in a suffocating gust that carries the weight of banishment. Those caught within it are flung back, lungs full of a wind that smells of empty thrones and revoked names."
    },
    {
      "id": "skill_001447",
      "name": "Exile Writ Severance",
      "role": "primary_attack",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "multi_projectile",
      "energy_cost": 11.8,
      "cooldown_seconds": 0.1,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "wind"
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.12
          }
        }
      ],
      "flavor_text": "The wind carries the king's darkest judgment, a sentence that strips breath from the condemned and feeds it back to the one who wields the decree. What is banished does not simply leave \u2014 it is unmade, its vitality claimed by the crown."
    },
    {
      "id": "skill_001450",
      "name": "Sovereign Seal Absolute",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "self_buff",
      "energy_cost": 24.0,
      "cooldown_seconds": 14.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.6
          }
        }
      ],
      "flavor_text": "Cold marble breathes outward in a pale corona, the Mad King's final unbreakable decree made manifest against all who would approach. The wind holds its breath around the sealed figure, as if the throne room itself refuses to let them fall."
    },
    {
      "id": "skill_001451",
      "name": "Sovereign Seal Shatters Marble",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 24.2,
      "cooldown_seconds": 4.7,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.7
          }
        }
      ],
      "flavor_text": "From the cold throne room floor, pale fissures erupt outward in a crown of stone \u2014 the king's final decree pressed into the earth itself. Those caught in its reach are pinned beneath the weight of a sovereignty that has lost all reason."
    },
    {
      "id": "skill_001452",
      "name": "Exile Writ Descends",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 14.9,
      "cooldown_seconds": 5.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 7.4,
            "stagger_seconds": 0.6
          }
        }
      ],
      "flavor_text": "A seal of darkened wind crashes into the earth where the Mad King's decree points, scattering the condemned outward like courtiers fleeing a throne room gone suddenly, terribly silent. The edict does not end \u2014 it lingers, gnawing at those too slow or too loyal to run."
    },
    {
      "id": "skill_001454",
      "name": "Throne Wind Decree",
      "role": "utility",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "self_buff",
      "energy_cost": 11.0,
      "cooldown_seconds": 18.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.12,
            "duration_seconds": 6.0
          }
        }
      ],
      "flavor_text": "The mad king's voice still echoes in these halls, and for a breath the air obeys it. Your strikes carry the weight of a crown no one dares remove."
    }
