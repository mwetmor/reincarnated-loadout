{
  "id": "class_0055",
  "name": "Mad King's Herald",
  "title_completion": "a Mad King's Herald",
  "flavor_text": "The edicts come before the flames \u2014 rolled in scorched parchment, sealed in still air, delivered on winds that smell of throne-room ash. You do not burn kingdoms out of malice; you burn them because the decree has been signed, the seal pressed, and the Mad King's word is, after all, law. Somewhere above you, a sovereign laughs, and you wonder if the crown was always on fire, or if that only started after you arrived.",
  "archetype_tag": "fire_controller",
  "energy_type": "mana",
  "role_orientation": "control",
  "range_profile": "long",
  "dominant_element": "fire",
  "seasonal_dominant_element": "brand",
  "is_act_boss": true,
