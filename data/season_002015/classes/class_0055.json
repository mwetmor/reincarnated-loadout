  "skills": [
    {
      "id": "skill_001308",
      "name": "Royal Decree Burns",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 17.3,
      "cooldown_seconds": 3.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "The Mad King's voice descends like a wind-fanned flame, and where his word lands, the stone floor remembers it forever. No petition survives the mark."
    },
    {
      "id": "skill_001309",
      "name": "Sovereign Seal Burns",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 12.0,
      "cooldown_seconds": 7.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 6.1
          }
        }
      ],
      "flavor_text": "The mad king's iron brand descends \u2014 not as punishment, but as ownership. The mark smolders through flesh and bone, a permanent declaration that you were noticed."
    },
    {
      "id": "skill_001310",
      "name": "Edict of Still Air",
      "role": "control",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ring",
      "energy_cost": 29.2,
      "cooldown_seconds": 10.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.6
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "A ring of scorched wind collapses inward from the throne's dais, searing the breath from every throat it touches. The Mad King's voice alone fills the silence that follows."
    },
    {
      "id": "skill_001311",
      "name": "Edict of Scorched Wind",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 21.1,
      "cooldown_seconds": 5.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 5.9
          }
        }
      ],
      "flavor_text": "The Mad King's final decree tears through the throne room as a howling gyre of branded flame, searing his mark into the stone and the flesh alike. Those caught within its radius carry the royal seal long after the fire dies \u2014 a permanent reminder that his word, however broken, still burns."
    },
    {
      "id": "skill_001312",
      "name": "Exile Writ Descends",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 23.0,
      "cooldown_seconds": 7.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 6.6,
            "stagger_seconds": 1.0
          }
        }
      ],
      "flavor_text": "A seal of shrouded wind crashes into the earth at the king's unspoken command, hurling the condemned outward as if the throne room itself rejects their presence. The dark gale lingers, stripping away flesh and dignity in equal measure."
    },
    {
      "id": "skill_001313",
      "name": "Exile Writ Descends",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 16.9,
      "cooldown_seconds": 5.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "The mad king's parchment unfurls into a howling vortex, stripping flesh and title alike from all who stand within its cursed radius. Those caught beneath it are unmade not by blade, but by the terrible weight of royal abandonment."
    },
    {
      "id": "skill_001314",
      "name": "Mad Proclamation Scorches All",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 11.0,
      "cooldown_seconds": 6.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 6.6
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "The king's decree hits the floor like a burning seal, and the wind carries no mercy \u2014 only the smell of iron and ruin. Those who linger in the circle learn what it means to be named by a madman."
    },
    {
      "id": "skill_001315",
      "name": "Branded Wind Edict",
      "role": "mobility",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "teleport",
      "energy_cost": 18.3,
      "cooldown_seconds": 9.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 6.7
          }
        }
      ],
      "flavor_text": "The mad king's decree scorches itself into flesh as you tumble through the throne room's howling drafts, iron words burning long after the voice that spoke them has gone silent. The mark does not fade \u2014 it was never meant to."
    },
    {
      "id": "skill_001316",
      "name": "Mad Proclamation Silences All",
      "role": "control",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ring",
      "energy_cost": 15.8,
      "cooldown_seconds": 9.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.1
          }
        }
      ],
      "flavor_text": "A gust tears through the throne room and the king's latest decree hangs in the air, branding every tongue within its circle with iron silence. No voice dares rise until the wind itself decides the edict has been satisfied."
    },
    {
      "id": "skill_001317",
      "name": "Sovereign Seal Stands",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "self_buff",
      "energy_cost": 21.2,
      "cooldown_seconds": 12.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.6
          }
        }
      ],
      "flavor_text": "The mad king's iron brand sears itself into the air around you, a ward of absolute authority that even the howling throne room gales cannot unmake. For one breathless moment, you are inviolable \u2014 marked, permanent, beyond reach."
    },
    {
      "id": "skill_001319",
      "name": "Royal Decree Immolation",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 29.5,
      "cooldown_seconds": 7.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 5.8
          }
        }
      ],
      "flavor_text": "The mad king's voice tears through the hall like a gale-fed furnace, and where his words land, the stone itself remembers the burning. No subject walks away unmarked."
    }
