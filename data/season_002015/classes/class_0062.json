        {
          "name": "damage",
          "params": {
            "magnitude": 3364,
            "element": "physical"
          }
        }
      ],
      "flavor_text": "The king's fury takes shape as a compressed gale that strikes like a royal judgment \u2014 sudden, total, and without appeal. Banners tear from their poles the moment the fist descends."
    },
    {
