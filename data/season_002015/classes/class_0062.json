  "skills": [
    {
      "id": "skill_001456",
      "name": "Exile Writ Howling",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 24.4,
      "cooldown_seconds": 6.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2018,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "The mad king's banishment tears through the court in a screaming chain, each soul it touches cast further into the cold dark beyond the throne room's shattered windows. Wind does not negotiate; it simply erases."
    },
    {
      "id": "skill_001457",
      "name": "Gauntlet Strike Decree",
      "role": "area_damage",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "ground_slam",
      "energy_cost": 22.8,
      "cooldown_seconds": 4.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2018,
            "element": "physical"
          }
        }
      ],
      "flavor_text": "The Mad King's fist comes down and the throne room floor splits open, wind howling through the cracks like a courtier screaming the verdict. Stone and sovereign fury hold the space long after the blow lands."
    },
    {
      "id": "skill_001545",
      "name": "Gauntlet of Mad Proclamation",
      "role": "utility",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 15.0,
      "cooldown_seconds": 18.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.35,
            "duration_seconds": 5.6
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.5
          }
        }
      ],
      "flavor_text": "A single blow carries the weight of a throne room silenced mid-sentence, the king's unfinished decree still hanging in the air like a held breath. The struck foe finds their voice stripped away as your strength swells with borrowed authority."
    },
    {
