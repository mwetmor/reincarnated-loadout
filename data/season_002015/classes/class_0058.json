  "skills": [
    {
      "id": "skill_001346",
      "name": "Bleeding Mad Proclamation",
      "role": "utility",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "circle",
      "energy_cost": 18.4,
      "cooldown_seconds": 19.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.26,
            "duration_seconds": 5.3
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.4
          }
        }
      ],
      "flavor_text": "A totem erupts in the throne room's stale air, pulsing with warm arterial light as the king's unhinged decree tears through the court \u2014 mouths clamp shut and blades grow hungry with borrowed fury."
    },
    {
      "id": "skill_001347",
      "name": "Exile Writ Descends",
      "role": "control",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 20.4,
      "cooldown_seconds": 15.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 4.9,
            "stagger_seconds": 0.6
          }
        }
      ],
      "flavor_text": "A cold vortex of sovereign darkness pulls the condemned inward before hurling them beyond the throne room's reach. The Mad King's decree needs no signature \u2014 only the hollow shriek of wind through empty halls."
    },
    {
      "id": "skill_001349",
      "name": "Exile Writ Pall",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 16.0,
      "cooldown_seconds": 6.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 3.5,
            "stagger_seconds": 0.6
          }
        }
      ],
      "flavor_text": "The mad king's decree tears through flesh like a wind that carries no warmth, only the cold finality of banishment. The condemned stumbles backward, marked by an edict that continues to fester long after the throne room falls silent."
    },
    {
      "id": "skill_001350",
      "name": "Exile Writ Unspoken",
      "role": "control",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 23.6,
      "cooldown_seconds": 17.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 7.5,
            "stagger_seconds": 0.8
          }
        }
      ],
      "flavor_text": "The mad king's silence is louder than any decree \u2014 a cold vortex opens in the throne room's heart, and those who stand before it are simply no longer there. The wind does not push; it erases."
    },
    {
      "id": "skill_001351",
      "name": "Exile Writ Descends",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 17.1,
      "cooldown_seconds": 6.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 5.2,
            "stagger_seconds": 0.6
          }
        }
      ],
      "flavor_text": "A darkness pools on the throne room floor like spilled ink from a mad king's decree, and those caught within are flung outward as though the crown itself has renounced them. The wind carries the verdict \u2014 there is no appeal."
    },
    {
      "id": "skill_000093",
      "name": null,
      "role": "control",
