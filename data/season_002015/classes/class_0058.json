    {
      "id": "skill_001354",
      "name": "Exile Writ Gale",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 27.0,
      "cooldown_seconds": 5.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "The mad king's banishment tears through the throne room like a howling wind, leaping from traitor to traitor with cold, sovereign fury. Those it touches are not merely struck \u2014 they are unmade from the court entire."
    },
    {
      "id": "skill_001356",
      "name": "Drowning Court Decree",
      "role": "area_damage",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "circle",
      "energy_cost": 26.3,
      "cooldown_seconds": 4.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "water"
          }
        },
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.44,
            "duration_seconds": 4.9
          }
        }
      ],
      "flavor_text": "A torrent of freezing wind-driven water erupts across the throne room floor, carrying the weight of a mad king's final word. Those caught in its sweep find their blood running cold, their limbs sluggish with the chill of royal displeasure."
    },
    {
      "id": "skill_001357",
      "name": "Exile Writ Gust",
      "role": "mobility",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "blink",
      "energy_cost": 18.6,
      "cooldown_seconds": 11.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "The Mad King's banishment carries no sword \u2014 only a sudden, suffocating wind that tears the condemned from where they stand. One moment present, the next simply gone, as though the throne room itself refused to remember them."
    },
    {
      "id": "skill_001358",
      "name": "Exile Writ Unseen",
      "role": "defensive",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "self_buff",
      "energy_cost": 20.3,
      "cooldown_seconds": 9.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.9
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.15,
            "duration_seconds": 9.4
          }
        }
      ],
      "flavor_text": "The wind closes around you like a sealed decree, cold and absolute, carrying the weight of a king's darkest silence. For a breath, nothing may touch what the throne has already cast out."
    }
  ],
