{
  "id": "class_0068",
  "name": "Bloodwind Herald",
  "title_completion": "a Bloodwind Herald",
  "flavor_text": "In the Throne Room of the Mad King, decrees are not merely spoken \u2014 they are bled into the air itself, carried on winds that smell of iron and forgotten oaths. The Bloodwind Herald does not fight with sword or spell, but with the sovereign weight of proclamations exhaled like storms, each edict a gust that flays the unworthy and sustains the faithful. To hear their voice is to feel the Court's obligation settle into your lungs, uninvited and permanent.",
  "archetype_tag": "experimental",
  "energy_type": "mana",
  "role_orientation": "damage",
  "range_profile": "long",
  "dominant_element": "water",
  "seasonal_dominant_element": "blood",
  "is_act_boss": false,
