  "skills": [
    {
      "id": "skill_001541",
      "name": "Breath of Royal Clemency",
      "role": "sustain",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "single_target",
      "energy_cost": 21.6,
      "cooldown_seconds": 11.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        },
        {
          "name": "heal_over_time",
          "params": {
            "tick_heal": 375,
            "duration_seconds": 5.3
          }
        }
      ],
      "flavor_text": "A warm gust moves through the throne room like a pardon spoken aloud, pressing blood back into wounds with the insistent pressure of a king's mercy. It lingers, coaxing the body to remember what it means to be alive and chosen."
    },
    {
      "id": "skill_001542",
      "name": "Bloodwind Royal Decree",
      "role": "utility",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "self_buff",
      "energy_cost": 12.5,
      "cooldown_seconds": 10.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.21,
            "duration_seconds": 6.2
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.28,
            "duration_seconds": 7.1
          }
        }
      ],
      "flavor_text": "A warm gust tears through the throne room carrying the scent of iron and old parchment, and for a breathless moment the Mad King's will becomes your own. Power floods the veins like a decree that cannot be refused."
    },
    {
      "id": "skill_001543",
      "name": "Bloodwind Court Tithe",
      "role": "primary_attack",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "multi_projectile",
      "energy_cost": 7.4,
      "cooldown_seconds": 1.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "water"
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.09
          }
        }
      ],
      "flavor_text": "The king's breath moves through you like a cold edict, drawing warmth from the wound before the body knows to grieve it. What the throne demands, the blood repays."
    },
    {
      "id": "skill_001544",
      "name": "Bloodwind Sovereign Seal",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "self_buff",
      "energy_cost": 24.0,
      "cooldown_seconds": 13.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.9
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.18,
            "duration_seconds": 9.8
          }
        }
      ],
      "flavor_text": "The throne room breathes in and the warm dark air folds around you like a decree no sword can contest. For a breathless moment, you are untouchable \u2014 the mad king's blood-soaked wind holds every blade at bay."
    },
    {
      "id": "skill_001545",
      "name": "Bloodwind Court Censure",
      "role": "control",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "aura",
      "energy_cost": 28.8,
      "cooldown_seconds": 16.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.21,
            "duration_seconds": 4.3
          }
        }
      ],
      "flavor_text": "The king's unspoken displeasure moves through the throne room like a cold draft through cracked stone, finding the condemned where they stand. Their blood slows, thickens, obedient at last to a will they cannot refuse."
    },
    {
      "id": "skill_001546",
      "name": "Drowned Royal Decree",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "single_target",
      "energy_cost": 27.6,
      "cooldown_seconds": 8.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "The king's voice rises to a shriek and the air tears open, flooding the throne room with a column of dark water that swallows the accused whole. What was once command is now current, cold and absolute."
    },
    {
      "id": "skill_001547",
      "name": "Bloodtide Court Edict",
      "role": "area_damage",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "circle",
      "energy_cost": 19.7,
      "cooldown_seconds": 5.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "water"
          }
        },
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.25,
            "duration_seconds": 4.6
          }
        }
      ],
      "flavor_text": "A ring of cold, vital pressure erupts outward from the caster like a decree no courtier dares refuse \u2014 the air turns wet and sharp, and those caught within it slow as if their blood has thickened with dread. The Mad King's throne room breathes this chill into every corner, a living reminder that obedience runs cold."
    },
    {
      "id": "skill_001548",
      "name": "Blood Sovereign Seal",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "self_buff",
      "energy_cost": 22.3,
      "cooldown_seconds": 12.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.6
          }
        }
      ],
      "flavor_text": "The mad king's decree tears you from harm's reach in a breath of hot copper air, wrapping you in a ward that pulses like a living wound. For a breathless moment, the throne room's draft cannot touch you \u2014 only the warm, dark authority of blood given freely to the crown."
    }
  ],
