{
  "id": "class_0056",
  "name": "Bloodwind Edictmancer",
  "title_completion": "a Bloodwind Edictmancer",
  "flavor_text": "In the Throne Room of the Mad King, the law is not written — it is bled into the air, carried on winds that smell of iron and scorched marble. The Bloodwind Edictmancer speaks in royal decrees that rupture veins and scatter courtiers like parchment in a gale. Every proclamation is a wound, every seal a verdict already carried out.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "water",
  "seasonal_dominant_element": "blood",
  "is_act_boss": false,
