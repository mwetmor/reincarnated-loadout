  "skills": [
    {
      "id": "skill_001320",
      "name": "Sovereign Seal Scatter",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "multi_projectile",
      "energy_cost": 6.7,
      "cooldown_seconds": 0.2,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The mad king's marble floors crack as shards of cold stone rise and fly outward like decrees flung from a trembling throne. Each fragment carries the weight of absolute authority, indifferent to who receives it."
    },
    {
      "id": "skill_001322",
      "name": "Mad Proclamation Drowns",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "single_target",
      "energy_cost": 34.1,
      "cooldown_seconds": 4.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "The king's voice breaks into water before it reaches the court, cascading from throat to throat until every noble chokes on the decree. What began as wind becomes a drowning tide, charged with the weight of a mind unmoored from reason."
    },
    {
      "id": "skill_001324",
      "name": "Throne Wind Royal Decree",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "single_target",
      "energy_cost": 34.5,
      "cooldown_seconds": 8.4,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 6.4
          }
        }
      ],
      "flavor_text": "The Mad King's voice tears through the hall in a chain of scorching edicts, each word a brand seared into flesh and stone alike. To be named is to burn — the decree does not end until every corner of the room has heard its verdict."
    },
    {
      "id": "skill_001325",
      "name": "Marble Edict Scatter",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 38.5,
      "cooldown_seconds": 7.2,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.12
          }
        }
      ],
      "flavor_text": "From the cold throne floor, pale shards rise and scatter outward like a king's final decree — each fragment claiming its pound of flesh before returning what it takes to the one who spoke."
    },
    {
      "id": "skill_001326",
      "name": "Sovereign Seal Unbroken",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "self_buff",
      "energy_cost": 17.4,
      "cooldown_seconds": 9.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.1
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.35,
            "duration_seconds": 5.8
          }
        }
      ],
      "flavor_text": "The mad king's decree still howls through the throne room like a gale that bends every curtain and courtier alike. You wear it now — iron-marked, permanent — a fortress of royal wind that no blade may question."
    },
    {
      "id": "skill_001327",
      "name": "Sovereign Seal of Pale Marble",
      "role": "utility",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "self_buff",
      "energy_cost": 14.0,
      "cooldown_seconds": 13.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.32,
            "duration_seconds": 7.8
          }
        }
      ],
      "flavor_text": "The cold throne room air stills and coalesces around a single chosen warrior, the Mad King's silent authority pressing into their bones like a hand pressed flat against smooth stone. For a breathless moment, every blow they land carries the terrible weight of a decree no one dares refuse."
    },
    {
      "id": "skill_001328",
      "name": "Sovereign Seal Unbroken",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "self_buff",
      "energy_cost": 17.1,
      "cooldown_seconds": 10.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.8
          }
        }
      ],
      "flavor_text": "The mad king's final decree hangs in the throne room air, iron-branded and absolute, wrapping the bearer in a wind that answers to no blade. For a breathless moment, the mark holds — permanent, unyielding, the last sane law in a court of howling chaos."
    },
    {
      "id": "skill_001329",
      "name": "Drowning Court Obligation",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "blood",
      "geometry_type": "single_target",
      "energy_cost": 30.9,
      "cooldown_seconds": 5.7,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        },
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.44,
            "duration_seconds": 4.4
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.06
          }
        }
      ],
      "flavor_text": "From the throne room's vaulted heights, a torrent of wind-whipped water descends in sovereign arcs, each droplet carrying the weight of a blood-sealed duty no courtier dares refuse. The cold seeps into bone before the wound even registers, and something vital — something warm — flows quietly back to the caster."
    },
    {
      "id": "skill_001331",
      "name": "Sovereign Seal of Still Stone",
      "role": "damage_over_time",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "totem",
      "energy_cost": 21.7,
      "cooldown_seconds": 4.9,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 15.5
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "A pale marble pillar erupts from the throne room floor, cold and absolute as a king's final judgment. The earth remembers every name pressed beneath it, and does not release them."
    },
    {
      "id": "skill_001332",
      "name": "Sovereign Seal Descent",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 28.8,
      "cooldown_seconds": 7.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.9
          }
        }
      ],
      "flavor_text": "The cold marble breathes upward in a pale eruption, pinning all who stand within it beneath the weight of a king's final, unhinged authority. The floor remembers every decree ever screamed into empty halls."
    }
  ],
