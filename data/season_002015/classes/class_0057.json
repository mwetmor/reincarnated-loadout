{
  "id": "class_0057",
  "name": "Marble-Tongued Royal Scribe",
  "title_completion": "a Marble-Tongued Royal Scribe",
  "flavor_text": "In the Throne Room of the Mad King, the decrees were never written in ink \u2014 they were carved into marble by those wise enough to know which words would outlast the man who spoke them. You did not wield a sword; you wielded the Sovereign Seal, and the earth itself learned to obey the stamp of your authority. When the winds of exile came howling through the gilded halls, it was not the king's voice that held the stones together \u2014 it was yours.",
  "archetype_tag": "earth_caster",
  "energy_type": "mana",
  "role_orientation": "damage",
  "range_profile": "medium",
  "dominant_element": "earth",
  "seasonal_dominant_element": "marble",
  "is_act_boss": false,
