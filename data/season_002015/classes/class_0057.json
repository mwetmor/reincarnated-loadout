  "skills": [
    {
      "id": "skill_001334",
      "name": "Sovereign Seal Descent",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "multi_projectile",
      "energy_cost": 12.4,
      "cooldown_seconds": 1.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The cold marble breathes upward in a pale column, an edict from the earth itself pressed into flesh and bone. What the Mad King's floor remembers, it returns without mercy."
    },
    {
      "id": "skill_001335",
      "name": "Sovereign Seal of Loam",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 23.6,
      "cooldown_seconds": 6.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The Mad King's crest splits the marble floor in a widening ring of packed earth and cold authority, each crack a sentence passed without appeal. What the seal touches does not crumble \u2014 it is simply declared beneath consideration."
    },
    {
      "id": "skill_001336",
      "name": "Sovereign Seal of Shattered Marble",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 25.3,
      "cooldown_seconds": 6.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The wind tears through the throne room and the floor answers \u2014 pale slabs split and launch outward in a cold, deliberate volley, as though the palace itself has passed judgment. Each fragment carries the weight of a king's last rational thought."
    },
    {
      "id": "skill_001338",
      "name": "Sovereign Seal Restored",
      "role": "sustain",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 34.7,
      "cooldown_seconds": 11.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        }
      ],
      "flavor_text": "Cold marble breathes again beneath the wind's passage, pale and whole, as though the throne itself has chosen to remember what it means to stand. A single subject is made sovereign over their own suffering."
    },
    {
      "id": "skill_001339",
      "name": "Sovereign Seal Absolute",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "self_buff",
      "energy_cost": 20.5,
      "cooldown_seconds": 12.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.8
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.11,
            "duration_seconds": 4.4
          }
        }
      ],
      "flavor_text": "The cold marble breathes outward in a sudden gust, and for a breathless moment the throne room falls silent \u2014 the wind itself recognizing the seal's authority. Nothing passes through it uninvited."
    },
    {
      "id": "skill_001340",
      "name": "Marble Wind Pardon",
      "role": "mobility",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "dash_attack",
      "energy_cost": 10.4,
      "cooldown_seconds": 6.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.27,
            "duration_seconds": 8.8
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The cold throne room exhales and you are elsewhere, the king's gaze passing through the space where you stood. Stone remembers your absence before your body does."
    },
    {
      "id": "skill_001341",
      "name": "Sovereign Seal Descends",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 20.8,
      "cooldown_seconds": 5.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The cold marble trembles as an invisible edict presses down from above, cracking the floor in a perfect circle of royal judgment. What the Mad King decrees, the earth itself obeys."
    },
    {
      "id": "skill_001342",
      "name": "Sovereign Seal Edict",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "self_buff",
      "energy_cost": 18.7,
      "cooldown_seconds": 8.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.2
          }
        }
      ],
      "flavor_text": "The wind stills in the throne room as an invisible brand sears the air around you, a permanent mark of inviolable authority. No blade, no gust, no whispered treachery passes through what the Mad King has decreed untouchable."
    },
    {
      "id": "skill_001343",
      "name": "Marble Edict Stillness",
      "role": "utility",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "circle",
      "energy_cost": 10.1,
      "cooldown_seconds": 12.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.11,
            "duration_seconds": 8.9
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.7
          }
        }
      ],
      "flavor_text": "A cold sovereign seal rises from the throne room floor, pale as forgotten law, and the air itself holds its breath. Those who stand within its reach strike harder, briefly \u2014 and enemies find their voices have been quietly revoked."
    },
    {
      "id": "skill_001344",
      "name": "Sovereign Seal of Still Air",
      "role": "sustain",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 29.6,
      "cooldown_seconds": 11.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        },
        {
          "name": "heal_over_time",
          "params": {
            "tick_heal": 375,
            "duration_seconds": 6.8
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.13,
            "duration_seconds": 8.2
          }
        }
      ],
      "flavor_text": "The mad king's marble throne breathes once, slow and cold, and the silence between his decrees becomes a mercy that holds the body together. Where wind forgets to move, wounds forget to bleed."
    },
    {
      "id": "skill_001345",
      "name": "Sovereign Seal of Still Marble",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "single_target",
      "energy_cost": 33.4,
      "cooldown_seconds": 7.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.4
          }
        }
      ],
      "flavor_text": "The throne room floor answers the king's last coherent command, a circle of pale stone surging upward to swallow the ground beneath a traitor's feet. Cold and absolute, it holds them there \u2014 rooted in the silence of a court that has learned not to speak."
    }
  ],
