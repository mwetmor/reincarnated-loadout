  "skills": [
    {
      "id": "skill_001436",
      "name": "Legitimate Claim Silenced",
      "role": "control",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 25.4,
      "cooldown_seconds": 11.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.7
          }
        }
      ],
      "flavor_text": "The mad king's court collapses inward like a held breath, and every tongue in the chamber forgets the shape of words. What was spoken is now property of the wind."
    },
    {
      "id": "skill_001437",
      "name": "Legitimate Claim Silenced",
      "role": "control",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 18.7,
      "cooldown_seconds": 18.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.3
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "A ring of holy wind expands outward from the throne's cracked foundation, carrying the weight of a decree no tongue may answer. Those caught within it find their voices stolen, swallowed by the mad king's unanswerable authority."
    },
    {
      "id": "skill_001438",
      "name": "Windswept Legitimate Claim",
      "role": "damage_over_time",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 22.1,
      "cooldown_seconds": 4.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "consecrate",
          "params": {
            "zone_duration_seconds": 5.0,
            "dot_tick_damage": 750,
            "heal_amplification_percent": 0.09
          }
        }
      ],
      "flavor_text": "Where the Mad King's decree once howled through the throne room, the air still burns with the memory of his righteous fury. The ground itself answers, radiating a slow and suffocating sovereignty over all who stand within it."
    },
    {
      "id": "skill_001439",
      "name": "Legitimate Claim Ascendant",
      "role": "utility",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 12.6,
      "cooldown_seconds": 15.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.29,
            "duration_seconds": 6.5
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.31,
            "duration_seconds": 7.0
          }
        }
      ],
      "flavor_text": "The wind through the throne room carries the weight of undeniable authority, sharpening the mind and replenishing what the court has long withheld. For one breathless moment, your right to act is absolute."
    },
