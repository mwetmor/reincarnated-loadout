  "skills": [
    {
      "id": "skill_001492",
      "name": "Throne Room Immolation",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 23.2,
      "cooldown_seconds": 4.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 6.3
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "The Mad King's final decree scorches the stone floor in a circle of sovereign fire, branding all who stand within as traitors to a crown that no longer exists. The flames remember the edict long after the voice that spoke it has gone silent."
    },
    {
      "id": "skill_001493",
      "name": "Sovereign Seal Ascendant",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "self_buff",
      "energy_cost": 20.5,
      "cooldown_seconds": 13.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.6
          }
        }
      ],
      "flavor_text": "The Mad King's brand sears the air itself, and the branded one vanishes \u2014 reappearing armored in the throne room's howling authority, wind pressed flat against an iron will. For a breathless moment, the decree holds: nothing may touch what the crown has claimed."
    },
    {
      "id": "skill_001494",
      "name": "Forked Royal Decree",
      "role": "primary_attack",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "multi_projectile",
      "energy_cost": 13.6,
      "cooldown_seconds": 0.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "The Mad King's voice splits the throne room air like a burning tongue, each syllable a separate brand searing into flesh and stone alike. Those who hear it marked cannot unhear it \u2014 the fire simply finds them first."
    },
    {
      "id": "skill_001495",
      "name": "Scorched Royal Decree",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "single_target",
      "energy_cost": 30.3,
      "cooldown_seconds": 7.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 6.6
          }
        }
      ],
      "flavor_text": "The Mad King's words leave the tongue as embers and arrive as wildfire, searing his will into flesh and bone alike. Those marked by his breath do not forget \u2014 they burn with the memory of it long after the court has fallen silent."
    },
    {
      "id": "skill_001496",
      "name": "Sovereign Seal Unbroken",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "self_buff",
      "energy_cost": 19.8,
      "cooldown_seconds": 10.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.1
          }
        }
      ],
      "flavor_text": "The cold marble breathes outward in a pale halo, a declaration no wind dare contradict. For one breathless moment, the Mad King's authority is absolute and the court falls silent."
    },
    {
      "id": "skill_001497",
      "name": "Royal Decree Scorched",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 27.0,
      "cooldown_seconds": 5.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "The Mad King's voice rings out from every stone, a wind of burning command that chars all who stand within its sovereign reach. To be named by the throne is to be unmade by it."
    },
    {
      "id": "skill_001498",
      "name": "Sovereign Seal Edict",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "self_buff",
      "energy_cost": 17.7,
      "cooldown_seconds": 8.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.6
          }
        }
      ],
      "flavor_text": "The mad king's brand burns itself into the air around you, and the throne room holds its breath \u2014 wind and law alike refuse to pass. For a breathless moment, you are untouchable, marked by a decree that even chaos respects."
    },
    {
      "id": "skill_001500",
      "name": "Sovereign Seal of Marble",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "marble",
      "geometry_type": "self_buff",
      "energy_cost": 23.8,
      "cooldown_seconds": 11.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.8
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.19,
            "duration_seconds": 9.9
          }
        }
      ],
      "flavor_text": "The cold throne room air stills completely, and pale stone light hardens around the body like a king's unbreakable decree. Wind finds no purchase here \u2014 only the smooth, indifferent surface of absolute authority."
    },
    {
      "id": "skill_001501",
      "name": "Royal Decree Vanish",
      "role": "mobility",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "teleport",
      "energy_cost": 17.1,
      "cooldown_seconds": 11.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.15,
            "duration_seconds": 4.6
          }
        }
      ],
      "flavor_text": "The king's word tears open the air itself, and you step through the wound before it can close. For a breathless moment, the wind cannot find you \u2014 you are where the decree has not yet arrived."
    },
    {
      "id": "skill_001502",
      "name": "Throne Aflame Decree",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "brand",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 22.7,
      "cooldown_seconds": 7.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 6.4
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "The Mad King's voice scorches the marble where it lands, a royal command that does not ask \u2014 it burns until answered. Wind carries the smell of singed iron through every corridor of the palace."
