  "skills": [
    {
      "id": "skill_000242",
      "name": "Border Erasure",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 19.0,
      "cooldown_seconds": 4.8,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "The wind does not cut — it unmakes the line between here and gone. Where the cartographer's circle closes, the air forgets what it once held."
    },
    {
      "id": "skill_000243",
      "name": "Border Erasure Veil",
      "role": "defensive",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "self_buff",
      "energy_cost": 16.8,
      "cooldown_seconds": 14.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.5
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.33,
            "duration_seconds": 9.3
          }
        }
      ],
      "flavor_text": "The tower's winds redraw the edges of the self, smearing the boundary between where you stand and where you are not. For a breath, the cartographer's ink refuses to fix your position on any map that means you harm."
    },
    {
      "id": "skill_000244",
      "name": "Cartographic Haze Salting",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "single_target",
      "energy_cost": 22.9,
      "cooldown_seconds": 5.7,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.12
          }
        }
      ],
      "flavor_text": "A brine-laced fog erupts from the tower's highest window, crystallizing mid-air into a dozen salt-edged currents that tear through flesh and draw the wound's warmth back into the caster's veins. The map remembers every coast it has ever charted."
    },
    {
      "id": "skill_000245",
      "name": "Border Erasure",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 25.9,
      "cooldown_seconds": 6.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        },
        {
          "name": "knockback",
          "params": {
            "distance": 4.0,
            "stagger_seconds": 0.7
          }
        }
      ],
      "flavor_text": "The wind tears through cartographic certainty, shredding the boundaries between mapped and unmapped in a single annihilating gust. What stood as known territory is scattered — edges undone, edges gone."
    },
    {
      "id": "skill_000248",
      "name": "Fixed Meridian Smolder",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "self_buff",
      "energy_cost": 19.1,
      "cooldown_seconds": 12.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.3
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.18,
            "duration_seconds": 6.3
          }
        }
      ],
      "flavor_text": "The cartographer vanishes in a breath of charcoal dust, reappearing exactly where the map says she must be. The residue settles into a shell — dense, pressurized, drawn in black lines that do not bend."
    },
    {
      "id": "skill_000249",
      "name": "Fixed Meridian Smolder",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "self_buff",
      "energy_cost": 16.6,
      "cooldown_seconds": 8.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.2
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.23,
            "duration_seconds": 6.3
          }
        }
      ],
      "flavor_text": "Charcoal lines burn themselves into the air around the caster, tracing borders that wind cannot cross. For one held breath, the map declares this body unmovable."
    },
    {
      "id": "skill_000250",
      "name": "Salt Chart Tumble",
      "role": "mobility",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "blink",
      "energy_cost": 16.4,
      "cooldown_seconds": 10.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.26,
            "duration_seconds": 4.6
          }
        }
      ],
      "flavor_text": "The cartographer rolls across the tower floor as crystalline salt maps bloom and crack beneath them, bitter wind tracing borders that slow whatever they touch. Each preserved line of the survey lingers in the air, a cold meridian no body crosses quickly."
    },
    {
      "id": "skill_000251",
      "name": "Smolder Cascade",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 16.8,
      "cooldown_seconds": 6.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 4.8
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Charcoal dust spirals down from the tower's drafts and ignites where it settles, tracing the outline of a map no one meant to draw. The burning holds its shape, patient and precise, as if the ground itself is being surveyed in ash."
    },
    {
      "id": "skill_000252",
      "name": "Border Erasure",
      "role": "primary_attack",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "multi_projectile",
      "energy_cost": 8.1,
      "cooldown_seconds": 0.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "A shrouded gust tears through the air like a cartographer striking a line from the map — what stood is simply gone. The wind does not destroy; it declares the territory was never there."
    },
    {
      "id": "skill_000254",
      "name": "Cartographic Haze Ward",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "self_buff",
      "energy_cost": 17.2,
      "cooldown_seconds": 14.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.3
          }
        }
      ],
      "flavor_text": "Salt crystals bloom outward from the caster's skin, mapping the body's meridians in bitter white lines that harden the air itself into an unyielding boundary. For a breath-held moment, the wind cannot find you — you are uncharted territory."
    }
  ],
