{
  "id": "class_0012",
  "name": "Cartographer of Erased Borders",
  "title_completion": "a Cartographer of Erased Borders",
  "flavor_text": "You arrived at the Tower with chalk-dusted fingers and a surveyor's squint, only to find that the maps here redraw themselves — and so, apparently, do you. Where you plant your staff, the wind stills and the smoke holds its shape, tracing boundaries that your enemies cannot cross and cannot find. The land remembers every line you burn into it; the trouble is, so does the land you've already unmade.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "fire",
  "seasonal_dominant_element": "charcoal",
  "is_act_boss": false,
