{
  "id": "class_0015",
  "name": "Cartographer of Unmapped Smoke",
  "title_completion": "a Cartographer of Unmapped Smoke",
  "flavor_text": "Every land I charted eventually burned, and every border I drew dissolved into ash and salt-wind. Now I map the places that shouldn't exist \u2014 the smoldering gaps between what was surveyed and what was erased. The Tower gave me the tools; the pall gave me the territory.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "wind",
  "seasonal_dominant_element": "pall",
