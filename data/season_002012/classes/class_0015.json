  "skills": [
    {
      "id": "skill_000301",
      "name": "Smolder Cascade Drafts",
      "role": "primary_attack",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "multi_projectile",
      "energy_cost": 8.2,
      "cooldown_seconds": 1.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Charcoal lines scatter outward from the tower's peak like wind-thrown survey marks, each fragment carrying the heat of a cartographer's final, furious correction. The air smells of burnt parchment before the strikes land."
    },
    {
      "id": "skill_000302",
      "name": "Border Erasure Pall",
      "role": "burst_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "single_target",
      "energy_cost": 25.9,
      "cooldown_seconds": 6.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "wind"
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.33,
            "duration_seconds": 4.1
          }
        }
      ],
      "flavor_text": "The wind tears through the cartographer's careful lines, shredding boundary and breath alike into a shroud of unmapped dark. Where the edges once held, only the howling remains."
    },
    {
      "id": "skill_000304",
      "name": "Smolder Cascade Survey",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 10.3,
      "cooldown_seconds": 7.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 375,
            "duration_seconds": 17.3
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "A pillar of compressed charcoal dust erupts from the tower's foundation, mapping the air itself in slow-burning black. What it touches, it claims \u2014 each breath of wind feeding the residue deeper into the wound."
    },
    {
      "id": "skill_000305",
      "name": "Cartographic Haze Brine",
      "role": "damage_over_time",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "circle",
      "energy_cost": 21.2,
      "cooldown_seconds": 4.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.39,
            "duration_seconds": 4.7
          }
        }
      ],
      "flavor_text": "A ring of salt-laden fog unfurls from the tower's highest meridian, each crystalline mote charting the slowest possible path through your flesh. The wind does not carry it away \u2014 it is the wind, preserved and bitter, circling without end."
    },
    {
      "id": "skill_000306",
      "name": "Cartographic Haze Salting",
      "role": "sustain",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "single_target",
      "energy_cost": 32.8,
      "cooldown_seconds": 8.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        }
      ],
      "flavor_text": "A bitter crystalline mist rises from ancient parchment, tracing the body's wounds as uncharted territory before sealing them with the preserving sting of salt-laced wind. What was lost becomes fixed, mapped, and whole again."
    },
    {
      "id": "skill_000307",
      "name": "Salt Chart Stillness",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "self_buff",
      "energy_cost": 21.5,
      "cooldown_seconds": 14.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.9
          }
        }
      ],
      "flavor_text": "The cartographer draws a final border around themselves \u2014 crystalline and absolute, preserving the body like a specimen pressed between survey pages. For a breathless moment, the wind finds no edge to cross."
    },
    {
      "id": "skill_000309",
      "name": "Border Erasure",
      "role": "mobility",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "blink",
      "energy_cost": 17.5,
      "cooldown_seconds": 9.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 7.4,
            "stagger_seconds": 0.9
          }
        }
      ],
      "flavor_text": "A shrouded wind tears through the Cartographer's Tower like a cartographer unmapping a rival's work \u2014 the target is not pushed so much as subtracted from where they stood. The pallor of uncharted dark settles in the space they leave behind."
    },
    {
      "id": "skill_000310",
      "name": "Border Erasure Gale",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 27.6,
      "cooldown_seconds": 7.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        },
        {
          "name": "knockback",
          "params": {
            "distance": 3.4,
            "stagger_seconds": 0.4
          }
        }
      ],
      "flavor_text": "The tower's unmapped edges collapse inward, a shrouding wind that devours the ground beneath enemy feet. What stood charted is swallowed whole, pulled into the pale dark between known and gone."
    },
    {
      "id": "skill_000311",
      "name": "Charcoal Stroke Survey",
      "role": "utility",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "self_buff",
      "energy_cost": 15.9,
      "cooldown_seconds": 16.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.32,
            "duration_seconds": 7.3
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.15,
            "duration_seconds": 5.8
          }
        }
      ],
      "flavor_text": "A swift circle of compressed ash sweeps outward from the caster's hand, tracing the invisible boundaries of power that only the tower's cartographers once knew. The residue settles into the air and the mind sharpens, drawing from the map what the map has always promised."
    },
    {
      "id": "skill_000313",
      "name": "Smolder Cascade Survey",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "single_target",
      "energy_cost": 39.2,
