  "skills": [
    {
      "id": "skill_000271",
      "name": "Cartographic Haze Crossing",
      "role": "mobility",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "blink",
      "energy_cost": 14.1,
      "cooldown_seconds": 10.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.25,
            "duration_seconds": 2.5
          }
        }
      ],
      "flavor_text": "The tower's salt-laden air folds into a crystalline corridor, and the caster steps through the blank space between mapped coordinates. Where they stood, a rime of bitter frost preserves the moment like a specimen pressed under glass."
    },
    {
      "id": "skill_000274",
      "name": "Cartographic Haze Meridian",
      "role": "damage_over_time",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "circle",
      "energy_cost": 23.1,
      "cooldown_seconds": 4.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.25,
            "duration_seconds": 11.2
          }
        }
      ],
      "flavor_text": "A crystalline pillar erupts from the mapped earth, exhaling salt-bitter wind that slows all who breathe it into the stillness of a preserved specimen. The tower's oldest charts show this place already marked as impassable."
    },
    {
      "id": "skill_000275",
      "name": "Charcoal Stroke Divide",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "multi_projectile",
      "energy_cost": 8.5,
      "cooldown_seconds": 0.4,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The cartographer's hand splits mid-stroke, forking two grey lines across the parchment that crack the earth below like a continent coming apart. What the map declares divided, the ground obeys."
    },
    {
      "id": "skill_000276",
      "name": "Charcoal Stroke Meridian",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "single_target",
      "energy_cost": 21.4,
      "cooldown_seconds": 8.9,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "From the tower's highest window, the cartographer draws the land in one sweeping gesture \u2014 and the earth obeys, splitting along lines only the wise can see. Slate shards rise in formation, charged with the patient fury of continents remembering their edges."
    },
    {
      "id": "skill_000278",
      "name": "Smolder Cascade Fork",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "single_target",
      "energy_cost": 30.0,
      "cooldown_seconds": 5.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Charcoal lines split across the air like a cartographer's final correction, each branch burning the map where it lands. The tower's winds carry the residue outward, tracing borders that exist only in ash."
    },
    {
      "id": "skill_000279",
      "name": "Charcoal Stroke Meridian",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "single_target",
      "energy_cost": 37.8,
      "cooldown_seconds": 8.4,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "From the tower's highest window, the cartographer draws one absolute line across the living earth \u2014 and the land fractures along it, grey and final. What the chalk marks, the stone obeys."
    },
    {
      "id": "skill_000280",
      "name": "Charcoal Stroke Transit",
      "role": "mobility",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "teleport",
      "energy_cost": 19.4,
      "cooldown_seconds": 9.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.21,
            "duration_seconds": 7.4
          }
        }
      ],
      "flavor_text": "A smear of compressed black opens a gap in the known world, and you step through the unmapped space between survey lines. For a breath, the tower's winds carry you faster than any cartographer could trace."
    },
    {
      "id": "skill_000281",
      "name": "Smolder Cascade Survey",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "single_target",
      "energy_cost": 38.6,
      "cooldown_seconds": 7.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Charcoal dust spirals upward from the tower's drafting table, gathering in slow, pressurized silence before collapsing into a single scorching line that rewrites what it touches. The cartographer holds the stroke until the map and the wound are the same thing."
    },
    {
      "id": "skill_000282",
      "name": "Fixed Meridian Hush",
      "role": "utility",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "circle",
      "energy_cost": 10.3,
      "cooldown_seconds": 16.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.13,
            "duration_seconds": 8.2
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.1
          }
        }
      ],
      "flavor_text": "The cartographer draws a final line through the target's voice, sealing it beneath grey wind and stone. For a breath, the tower's silence becomes theirs."
    },
    {
      "id": "skill_000284",
      "name": "Salt Line Meridian",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "self_buff",
      "energy_cost": 17.5,
      "cooldown_seconds": 13.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.1
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.28,
            "duration_seconds": 4.2
          }
        }
      ],
      "flavor_text": "A bitter crystalline boundary snaps into place around the caster, its edges sharp as surveyed borders drawn in salt. The wind howls against it and finds no purchase, every gust mapped and denied."
    }
  ],
