{
  "id": "class_0014",
  "name": "Wind-Traced Cartomancer",
  "title_completion": "a Wind-Traced Cartomancer",
  "flavor_text": "Armed with charcoal and salt-stained parchment, they map the world by burning its edges first. From the Cartographer's Tower, their haze rewrites borders mid-battle \u2014 what the wind erases, their Fixed Meridian refuses to forget. Every stroke is both a survey and a sentence.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "earth",
  "seasonal_dominant_element": "slate",
  "is_act_boss": false,
