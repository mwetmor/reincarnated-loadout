{
  "id": "class_0016",
  "name": "Chartbound Stormscribe",
  "title_completion": "a Chartbound Stormscribe",
  "flavor_text": "Every map is a lie until the lightning proves it true. She traces meridians across the sky with charcoal-blackened fingers, and where her lines cross, the air tears open in crackling arcs of Parallel Transit. The Cartographer's Tower did not teach her to draw the world \u2014 it taught her to redraw it, one scorched border at a time.",
  "archetype_tag": "lightning_mage",
  "energy_type": "mana",
  "role_orientation": "damage",
  "range_profile": "close",
  "dominant_element": "lightning",
