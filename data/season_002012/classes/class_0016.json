  "skills": [
    {
      "id": "skill_000369",
      "name": "Parallel Transit Strike",
      "role": "primary_attack",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "melee_strike",
      "energy_cost": 10.5,
      "cooldown_seconds": 0.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "lightning"
          }
        },
        {
          "name": "shock",
          "params": {
            "duration_seconds": 0.6
          }
        }
      ],
      "flavor_text": "A charted line snaps taut between two points, carrying the storm's full voltage in a single surveyed instant. The air smells of scorched vellum long after the target falls."
    },
    {
      "id": "skill_000370",
      "name": "Parallel Transit Arc",
      "role": "burst_damage",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "chain_lightning",
      "energy_cost": 26.4,
      "cooldown_seconds": 6.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "lightning"
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.11
          }
        }
      ],
      "flavor_text": "The cartographer's breath holds, then releases \u2014 a sweeping charge that maps every nerve and meridian in a single crackling stroke. What the lightning claims, the surveyor keeps."
    },
    {
      "id": "skill_000371",
      "name": "Parallel Transit Gyre",
      "role": "area_damage",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "chain_lightning",
      "energy_cost": 16.5,
      "cooldown_seconds": 6.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "lightning"
          }
        }
      ],
      "flavor_text": "From the tower's highest lens, the wind finds every mapped corridor at once, threading lightning along invisible meridians in a single catastrophic rotation. The air smells of ozone and scorched parchment long after the last arc fades."
    },
    {
      "id": "skill_000372",
      "name": "Parallel Transit Strike",
      "role": "damage_over_time",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 18.1,
      "cooldown_seconds": 5.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shock",
          "params": {
            "duration_seconds": 2.0
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "lightning"
          }
        }
      ],
      "flavor_text": "A current of mapped lightning traces the exact meridian between two points, burning the route into living flesh. The wind carries the smell of scorched parchment long after the arc fades."
    },
    {
      "id": "skill_000373",
      "name": "Fixed Meridian Gust",
      "role": "defensive",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 20.9,
      "cooldown_seconds": 8.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.8
          }
        }
      ],
      "flavor_text": "The tower's oldest wind finds you and holds \u2014 a cartographic absolute drawn in breathless amber around your form. For a moment, the map says you cannot be moved."
    }
  ],
