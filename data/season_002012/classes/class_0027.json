  "skills": [
    {
      "id": "skill_000586",
      "name": "Cartographic Haze",
      "role": "damage_over_time",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "circle",
      "energy_cost": 19.5,
      "cooldown_seconds": 7.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.42,
            "duration_seconds": 3.2
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "water"
          }
        }
      ],
      "flavor_text": "A bitter salt-wind unrolls across the ground like a surveyor's last unfinished chart, and whatever it touches is preserved mid-motion \u2014 slowed, stung, and slowly undone by the cold it carries. The Tower's cartographers once warned that some territories, once mapped in salt, refuse to thaw."
    },
    {
      "id": "skill_000587",
      "name": "Cartographic Haze Brine",
      "role": "area_damage",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "circle",
      "energy_cost": 24.3,
      "cooldown_seconds": 6.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "A circle of salted fog unrolls across the ground like a surveyor's dampened chart, crystallizing the air into bitter, cutting mist. Where the haze settles, flesh and stone alike are mapped in white ruin."
    },
    {
      "id": "skill_000588",
      "name": "Fixed Meridian Survey",
      "role": "sustain",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "single_target",
      "energy_cost": 20.2,
      "cooldown_seconds": 9.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        },
        {
          "name": "heal_over_time",
          "params": {
            "tick_heal": 375,
            "duration_seconds": 9.9
          }
        }
      ],
      "flavor_text": "From the tower's highest window, the healer traces a steady line across the patient's form \u2014 grey slate light following the contour like a cartographer redrawing a coastline that had forgotten its own shape. The wind holds still for this, as if even the air refuses to interrupt the work."
    },
    {
      "id": "skill_000589",
      "name": "Salt Wind Reckoning",
      "role": "utility",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "circle",
      "energy_cost": 14.0,
      "cooldown_seconds": 10.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.11,
            "duration_seconds": 9.2
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.6
          }
        }
      ],
      "flavor_text": "The cartographer draws breath and the air crystallizes around her \u2014 bitter, still, absolute. For a moment, the world holds its tongue while her instruments find true bearing."
    },
    {
      "id": "skill_000590",
      "name": "Salt Line Meridian",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "self_buff",
      "energy_cost": 21.3,
      "cooldown_seconds": 11.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.8
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.15,
            "duration_seconds": 8.6
          }
        }
      ],
      "flavor_text": "A bitter crystalline boundary etches itself into the air around the caster, each grain holding fast against the wind's insistence. The tower's old surveys say some borders were never meant to be crossed."
    },
    {
      "id": "skill_000591",
      "name": "Fixed Meridian Holds",
      "role": "damage_over_time",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "totem",
      "energy_cost": 20.4,
      "cooldown_seconds": 6.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 10.4
          }
        }
      ],
      "flavor_text": "A slate totem erupts from the earth at the cartographer's command, its layered grey faces etched with wind-lines that pin the world in place. The air around it stops moving entirely, and whatever stands within finds its feet written into the map."
    },
    {
      "id": "skill_000592",
      "name": "Cartographic Haze Saltward",
      "role": "mobility",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "blink",
      "energy_cost": 19.4,
      "cooldown_seconds": 6.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "water"
          }
        }
      ],
      "flavor_text": "The tower's brine-laced fog swallows distance whole, depositing the traveler at coordinates only the wind remembers. What arrives is preserved in salt, sharp and exact as a meridian drawn in the dark."
    },
