          }
        }
      ],
      "flavor_text": "A bitter crystalline torrent erupts from the tower's highest window, mapping cold ruin across whatever it touches. The water it carries tastes of preserved distance and forgotten coastlines."
    },
    {
      "id": "skill_000594",
      "name": "Charcoal Stroke Meridian",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "single_target",
      "energy_cost": 28.2,
      "cooldown_seconds": 8.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.28,
            "duration_seconds": 5.2
          }
        }
      ],
      "flavor_text": "From the Tower's highest window, the cartographer drags a charged finger across the living map \u2014 grey pressure splits into leaping arcs, each strike redrawing the earth beneath. For a breathless moment, the ground remembers every border it has ever held."
    },
    {
      "id": "skill_000596",
      "name": "Cartographic Haze Surge",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "single_target",
