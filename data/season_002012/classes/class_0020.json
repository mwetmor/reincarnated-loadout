{
  "id": "class_0020",
  "name": "Smoldering Cartographer",
  "title_completion": "a Smoldering Cartographer",
  "flavor_text": "From the top of the Cartographer's Tower, she redrew the world in charcoal and controlled fire \u2014 borders were not lines on parchment but walls of slow-burning ash she alone could raise or erase. Every map she charted scorched itself into existence, territories marked by smoldering meridians that lingered long after the ink had burned away. To cross her survey was to enter terra incognita, a haze of heat and smoke where the only fixed point was her will.",
  "archetype_tag": "fire_controller",
  "energy_type": "mana",
  "role_orientation": "control",
  "range_profile": "long",
  "dominant_element": "fire",
  "seasonal_dominant_element": "charcoal",
  "is_act_boss": false,
