  "skills": [
    {
      "id": "skill_000514",
      "name": "Smolder Cascade",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 18.0,
      "cooldown_seconds": 7.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 4.2
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Charcoal dust lifts from the tower's drafting tables and ignites mid-air, settling into a slow-burning circle that chars whatever the cartographer once claimed as measured ground. The heat does not rush \u2014 it lingers, tracing its boundary with the patience of a surveyor who knows the land will yield."
    },
    {
      "id": "skill_000515",
      "name": "Fixed Meridian Ring",
      "role": "control",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "vortex_pull",
      "energy_cost": 17.1,
      "cooldown_seconds": 9.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 1.6
          }
        }
      ],
      "flavor_text": "A grey circle of pressed wind fans outward from the caster's feet, charting the ground beneath enemies as immovable territory. Those caught within the survey find their steps erased from the map entirely, held fast where the cartographer has drawn the line."
    },
    {
      "id": "skill_000516",
      "name": "Smolder Cascade Survey",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 24.0,
      "cooldown_seconds": 5.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Charcoal dust lifts from the tower's drafting tables and spirals outward in a burning gyre, mapping every surface it touches in ash and ember. The wind reads the room before the fire does."
    },
    {
      "id": "skill_000517",
      "name": "Terra Incognita Ring",
      "role": "control",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "ring",
      "energy_cost": 17.1,
      "cooldown_seconds": 8.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.9
          }
        }
      ],
      "flavor_text": "A halo of charcoal dust blooms outward from the tower's apex, smothering every voice it crosses in a silence as absolute as uncharted territory. The wind carries the residue in a perfect circle, redrawing the map with absence."
    },
    {
      "id": "skill_000518",
      "name": "Charcoal Stroke Meridian",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "slate",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 18.8,
      "cooldown_seconds": 5.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.7
          }
        }
      ],
      "flavor_text": "The cartographer drags a finger across the living map and the ground below cracks open in long grey seams, pinning the world in place. What is drawn cannot move until the line is finished."
    },
