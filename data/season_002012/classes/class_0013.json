  "skills": [
    {
      "id": "skill_000256",
      "name": "Salt Chart Volley",
      "role": "primary_attack",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "multi_projectile",
      "energy_cost": 7.7,
      "cooldown_seconds": 0.2,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "water"
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.06
          }
        }
      ],
      "flavor_text": "Bitter crystalline needles scatter outward like survey lines etched across a soaked map, each one drawing back a thin thread of what they pierce. The tower's winds carry them true, and the cartographer's hand never wavers."
    },
    {
      "id": "skill_000257",
      "name": "Border Erasure Veil",
      "role": "utility",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "self_buff",
      "energy_cost": 18.2,
      "cooldown_seconds": 19.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.34,
            "duration_seconds": 6.4
          }
        }
      ],
      "flavor_text": "The cartographer smudges the boundary between self and storm, and for a breathless moment the wind strikes through them rather than past. What the map cannot contain, the body becomes."
    },
    {
      "id": "skill_000258",
      "name": "Smolder Cascade Survey",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "single_target",
      "energy_cost": 30.0,
      "cooldown_seconds": 4.2,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "A single charcoal line drawn across the target ignites everything the cartographer once measured — the heat follows the map, not the territory. What burns has already been claimed."
    },
    {
      "id": "skill_000259",
      "name": "Cartographic Haze Salt Tide",
      "role": "area_damage",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "circle",
      "energy_cost": 15.8,
      "cooldown_seconds": 3.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "A brine-heavy fog descends from the tower's highest windows, crystallizing mid-air into a bitter map of ruin before crashing earthward. The salt preserves the moment of impact like a specimen pinned beneath glass."
    },
    {
      "id": "skill_000260",
      "name": "Border Erasure Gale",
      "role": "burst_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "single_target",
      "energy_cost": 34.7,
      "cooldown_seconds": 4.8,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "A shrouding wind tears through the mapped world, unraveling the lines between territories in a chain of desolate, howling force. Where the cartographer once drew borders, only scoured emptiness remains."
    },
    {
      "id": "skill_000263",
      "name": "Border Erasure Shroud",
      "role": "defensive",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "self_buff",
      "energy_cost": 21.5,
      "cooldown_seconds": 9.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.5
          }
        }
      ],
      "flavor_text": "The cartographer steps sideways through a fold in the mapped world, wrapped in a pall of uncharted dark where no blade can find purchase. For a breath, they exist between territories — neither here nor there, untouchable."
    },
    {
      "id": "skill_000264",
      "name": "Border Erasure Pall",
      "role": "defensive",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "self_buff",
      "energy_cost": 16.4,
      "cooldown_seconds": 14.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.3
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.24,
            "duration_seconds": 7.4
          }
        }
      ],
      "flavor_text": "The cartographer unmakes the boundary between here and elsewhere, and for a breathless moment the wind cannot find you. You exist only as a smear of ink on a map no one holds."
    },
    {
      "id": "skill_000265",
      "name": "Smolder Cascade Survey",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "charcoal",
      "geometry_type": "single_target",
      "energy_cost": 39.7,
      "cooldown_seconds": 7.4,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "From the tower's highest window, compressed charcoal lines leap between fixed points on the map, each stroke igniting the next in a chain of blackened meridians. The cartographer's hand never lifts — the fire simply continues the survey."
    },
    {
      "id": "skill_000266",
      "name": "Salt Meridian Totem",
      "role": "damage_over_time",
      "canonical_element": "water",
      "seasonal_element": "salt",
      "geometry_type": "circle",
      "energy_cost": 16.6,
      "cooldown_seconds": 7.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.25,
            "duration_seconds": 19.6
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "water"
          }
        }
      ],
      "flavor_text": "A crystalline marker is driven into the ground, exhaling a bitter cold that seeps into cartographic lines no map can erase. The air around it tastes of ocean and old parchment, slowing everything that dares cross its fixed boundary."
    },
    {
      "id": "skill_000267",
      "name": "Border Erasure",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 20.5,
      "cooldown_seconds": 6.6,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        },
        {
          "name": "knockback",
          "params": {
            "distance": 4.1,
            "stagger_seconds": 0.7
          }
        }
      ],
      "flavor_text": "A shroud of wind tears across the cartographer's unfinished lines, unmapping flesh and bone with each leaping arc. What stood is scattered, the boundary between presence and absence quietly, finally dissolved."
    }
  ],
