{
  "id": "class_0013",
  "name": "Cartographer of Unmapped Winds",
  "title_completion": "a Cartographer of Unmapped Winds",
  "flavor_text": "Armed with charcoal-dusted fingers and charts that dissolve the borders of the world, you map territories that refuse to stay still. From the Cartographer's Tower, salt-winds carry your surveys across shifting frontiers, rewriting coastlines and erasing the edges of kingdoms that never asked to be found. What you chart becomes real — and what you erase is simply... gone.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "water",
  "seasonal_dominant_element": "salt",
  "is_act_boss": false,
