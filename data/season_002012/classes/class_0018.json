{
  "id": "class_0018",
  "name": "Unmapped Cartographer",
  "title_completion": "an Unmapped Cartographer",
  "flavor_text": "She once charted every border in the known world from the top of the Cartographer's Tower \u2014 until the wind erased her name from every map she ever made. Now she walks the Terra Incognita between light and shadow, sketching oblivion in charcoal strokes that swallow armies whole. The tower still stands, but no map inside it will acknowledge she exists.",
  "archetype_tag": "shadow_mage",
  "energy_type": "mana",
  "role_orientation": "damage",
  "range_profile": "long",
