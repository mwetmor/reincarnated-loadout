  "skills": [
    {
      "id": "skill_000498",
      "name": "Terra Incognita Fork",
      "role": "primary_attack",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "multi_projectile",
      "energy_cost": 10.8,
      "cooldown_seconds": 1.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "Where the cartographer's quill splits, shadow bleeds into unmapped territory, swallowing light along two diverging edges of the known world. The wind carries ink that has never dried."
    },
    {
      "id": "skill_000499",
      "name": "Terra Incognita Fork",
      "role": "burst_damage",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 38.6,
      "cooldown_seconds": 4.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "Where the cartographer's quill splits into unmapped territory, shadow blooms outward in branching strokes that swallow light whole. The wind carries no echo back from these uncharted edges."
    },
    {
      "id": "skill_000500",
      "name": "Terra Incognita Gale",
      "role": "area_damage",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 15.2,
      "cooldown_seconds": 5.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "shadow"
          }
        },
        {
          "name": "drain",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 8.2
          }
        }
      ],
      "flavor_text": "Where the cartographer's ink never reached, a shadow-wind scours the ground in slow, hungry circles, pulling the light from those caught within its unmapped edge. What stands inside is gradually erased from the known world."
    },
    {
      "id": "skill_000501",
      "name": "Terra Incognita Drift",
      "role": "damage_over_time",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 21.6,
      "cooldown_seconds": 7.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "drain",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 5.5
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "A circle of unmapped shadow blooms across the ground, its edges shifting like coastlines no cartographer dared finish. The wind carries nothing out of it \u2014 only draws things in, slowly, until they are gone."
    },
    {
      "id": "skill_000502",
      "name": "Terra Incognita Veil",
      "role": "defensive",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 15.5,
      "cooldown_seconds": 13.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.5
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.16,
            "duration_seconds": 8.9
          }
        }
      ],
      "flavor_text": "The unmapped edges of the known world fold inward, wrapping the cartographer in a shroud of uncharted wind and shadow. What cannot be named cannot be struck."
    }
