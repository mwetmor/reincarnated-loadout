            "magnitude": 625,
            "element": "water"
          }
        }
      ],
      "flavor_text": "Brackish water splits at the wrist and finds two throats at once, carrying the city's old sickness in every drop. It does not wash \u2014 it preserves what it ruins."
    },
    {
      "id": "skill_001275",
      "name": "Chalk Ward Rising",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
