  "skills": [
    {
      "id": "skill_001268",
      "name": "Miasmal Seep",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 22.0,
      "cooldown_seconds": 9.8,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "Salt-heavy water splits into a dozen bitter streams, each one carrying the memory of the plague city's flooded streets. They do not wash clean \u2014 they preserve what they ruin."
    },
    {
      "id": "skill_001269",
      "name": "Pitch Bloom Contagion Arc",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "single_target",
      "energy_cost": 25.1,
      "cooldown_seconds": 8.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 6.8
          }
        }
      ],
      "flavor_text": "Black tar ignites across the waterlogged district in a single crackling breath, leaping between the fevered and the fallen alike. What the water cannot drown, the pitch carries onward, burning."
    },
    {
      "id": "skill_001270",
      "name": "Chalk Ward Deluge",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 27.1,
      "cooldown_seconds": 3.9,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The healer's white dust dissolves into the standing water, spreading outward in pale tendrils that harden the ground into cracking slabs beneath infected feet. What once protected now crushes, the city's soft bones turned weapon."
    },
    {
      "id": "skill_001271",
      "name": "Chalk Ward Tide",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 19.6,
      "cooldown_seconds": 6.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.7
          }
        }
      ],
      "flavor_text": "A ring of pale sediment erupts from the earth, soft as quarantine dust, locking the afflicted in place where the city's chalk streets once held the dying still. The ground remembers every body pressed into it."
    },
    {
      "id": "skill_001273",
      "name": "Miasmal Seep Brine",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
