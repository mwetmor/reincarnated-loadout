      "flavor_text": "Salt-heavy water splits into hungering forks, each tendril drinking deep from whatever warmth it finds. The city remembers this cold \u2014 it has always known how to preserve the dead."
    },
    {
      "id": "skill_001274",
      "name": "Miasmal Seep",
      "role": "primary_attack",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "multi_projectile",
      "energy_cost": 13.8,
