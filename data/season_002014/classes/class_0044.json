  "skills": [
    {
      "id": "skill_001113",
      "name": "Quarantine Light Spill",
      "role": "primary_attack",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "multi_projectile",
      "energy_cost": 8.2,
      "cooldown_seconds": 0.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "holy"
          }
        },
        {
          "name": "consecrate",
          "params": {
            "zone_duration_seconds": 6.2,
            "dot_tick_damage": 750,
            "heal_amplification_percent": 0.11
          }
        }
      ],
      "flavor_text": "A focused beam of consecrated radiance strikes the afflicted and lingers, pooling in the wound like light that refuses to leave a condemned room. The ground it touches burns clean, indifferent to suffering."
    },
    {
      "id": "skill_001114",
      "name": "Quarantine Light Surge",
      "role": "burst_damage",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 34.2,
      "cooldown_seconds": 6.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "holy"
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.18,
            "duration_seconds": 9.5
          }
        }
      ],
      "flavor_text": "Drawn from the city's sealed wards, a held breath of holy radiance leaps between the infected in cascading arcs of burning white. What the plague claimed, the light reclaims \u2014 vessel by vessel, without mercy."
    },
    {
      "id": "skill_001115",
      "name": "Quarantine Light Seep",
      "role": "area_damage",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 17.9,
      "cooldown_seconds": 7.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "A searing luminance bleeds from one fevered body to the next, tracing the invisible paths of contagion through the flooded streets. What the plague connected, the light now judges."
    },
    {
      "id": "skill_001116",
      "name": "Quarantine Light Totem",
      "role": "damage_over_time",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 16.6,
      "cooldown_seconds": 5.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "consecrate",
          "params": {
            "zone_duration_seconds": 5.0,
            "dot_tick_damage": 375,
            "heal_amplification_percent": 0.18
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "A pale ward erupts from the cobblestones, flooding the afflicted ground with a searing, clinical glow that does not comfort. What lingers in its radius does not linger long."
    },
    {
      "id": "skill_001117",
      "name": "Chalk Ward Rising",
      "role": "defensive",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 21.7,
      "cooldown_seconds": 14.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.6
          }
        }
      ],
      "flavor_text": "The body becomes a sealed district, ringed in pale luminescence that the sickness cannot cross. For a breath and a half, nothing enters that has not been permitted."
    },
    {
      "id": "skill_001118",
      "name": "Quarantine Light Offering",
      "role": "utility",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 17.0,
      "cooldown_seconds": 14.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.27,
            "duration_seconds": 9.8
          }
        }
      ],
      "flavor_text": "A totem rises from the waterlogged stones, bleeding pale radiance through the city's perpetual fog. Those who stand within its glow find their strikes sharpened, as though the sickness itself has taught them where flesh yields."
    }
