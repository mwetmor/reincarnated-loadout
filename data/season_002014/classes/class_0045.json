  },
  "skills": [
    {
      "id": "skill_001174",
      "name": "Door Unmarking Touch",
      "role": "primary_attack",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "multi_projectile",
      "energy_cost": 10.9,
      "cooldown_seconds": 0.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "A threshold dissolves where the finger lands, and what lived behind it spills out cold and wrong. The Plague City knows this erasure \u2014 it has watched whole addresses forget themselves overnight."
    },
    {
      "id": "skill_001175",
      "name": "Door Unmarking Tide",
      "role": "burst_damage",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 31.0,
      "cooldown_seconds": 9.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "shadow"
          }
        },
        {
          "name": "drain",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 5.3
          }
        }
      ],
      "flavor_text": "A shadow-soaked ripple departs from the caster's fingertips and careens through the infected alleyways, peeling names from doorframes as it passes. What it touches forgets it was ever whole."
    },
    {
      "id": "skill_001176",
      "name": "Miasmal Door Unmarking",
      "role": "area_damage",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 22.8,
      "cooldown_seconds": 3.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "A sickness of shadow leaps between the condemned, each body a stepping stone for something that has learned to travel without permission. The plague city remembers every door it has passed through."
    },
    {
      "id": "skill_001177",
      "name": "Miasmal Seep Ward",
      "role": "damage_over_time",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 13.7,
      "cooldown_seconds": 5.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "drain",
          "params": {
            "tick_damage": 375,
            "duration_seconds": 12.1
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "A totem of blackened chalk rises from the waterlogged street, weeping shadow into the standing flood. What it touches does not die quickly \u2014 it dissolves, the way the city does, in slow and patient increments."
    },
    {
      "id": "skill_001178",
      "name": "Door Unmarking Ward",
      "role": "defensive",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 17.3,
      "cooldown_seconds": 10.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.3
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.23,
            "duration_seconds": 4.6
          }
        }
      ],
      "flavor_text": "The infected city folds around you, and for a breath you exist between its walls \u2014 chalk-white and unreachable. Whatever hunts you loses the scent of your presence entirely."
    },
    {
      "id": "skill_001179",
      "name": "Door Unmarking Tide",
      "role": "sustain",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 33.2,
      "cooldown_seconds": 8.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        }
      ],
      "flavor_text": "Where the plague's shadow has eaten through a name, the water finds the wound and fills it back with knowing. The self returns, briefly, like a face remembered in standing water."
    }
  ],
