{
  "id": "class_0045",
  "name": "Unmarked Plague Cartographer",
  "title_completion": "an Unmarked Plague Cartographer",
  "flavor_text": "They say the Plague City's doors no longer bear names \u2014 because she erased them, one by one, until the sickness forgot where it lived. She walks the quarantine lines with chalk-dusted fingers and brine-soaked maps, tracing the unmarked thresholds where contagion seeps through the dark. Where others flee the miasma, she breathes it in and breathes it back out as shadow.",
  "archetype_tag": "shadow_mage",
  "energy_type": "mana",
  "role_orientation": "damage",
  "range_profile": "long",
  "dominant_element": "shadow",
  "seasonal_dominant_element": null,
  "is_act_boss": false,
  "color_palette": [
    631464,
