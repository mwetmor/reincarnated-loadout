  "skills": [
    {
      "id": "skill_001193",
      "name": "Pall Surge Bloom",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "miasma",
      "geometry_type": "vortex_pull",
      "energy_cost": 23.3,
      "cooldown_seconds": 7.2,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "A held breath releases \u2014 the air above the cobblestones curdles outward in a slow, suffocating wave, peeling rot from stone and marrow alike. Whatever stands within the circle learns what the city's dead already know."
    },
    {
      "id": "skill_001195",
      "name": "Pall Surge Idol",
      "role": "utility",
      "canonical_element": "wind",
      "seasonal_element": "miasma",
      "geometry_type": "self_buff",
      "energy_cost": 10.4,
      "cooldown_seconds": 15.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.14,
            "duration_seconds": 7.4
          }
        }
      ],
      "flavor_text": "A fetish of blackened bone rises from the cobblestones, exhaling a column of plague-thick air that sharpens every blade passing through it. The miasma does not weaken here \u2014 it chooses sides."
    },
    {
      "id": "skill_001196",
      "name": "Chalk Ward Cleave",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "multi_projectile",
      "energy_cost": 5.7,
      "cooldown_seconds": 0.7,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.3
          }
        }
      ],
      "flavor_text": "The earth splits in two pale tongues, soft and decisive as a chalk line drawn through standing water. What it marks stays marked, feet sinking into the silted ground like a verdict."
    },
    {
      "id": "skill_001197",
      "name": "Pall Surge",
      "role": "mobility",
      "canonical_element": "wind",
      "seasonal_element": "miasma",
      "geometry_type": "blink",
      "energy_cost": 15.3,
      "cooldown_seconds": 8.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 7.1,
            "stagger_seconds": 0.4
          }
        }
      ],
      "flavor_text": "The miasma thickens into a wall of breathless air, hurling all who stand in its path backward through the choking murk. Where the body moves, the plague follows \u2014 and so do its consequences."
    },
    {
      "id": "skill_001198",
      "name": "Chalk Seam Breach",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 17.5,
      "cooldown_seconds": 6.2,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "A fissure tears through the waterlogged earth in a pale, crumbling line \u2014 the city's soft foundations splitting open like a wound that has finally stopped holding. What the plague softened, the ground swallows."
    },
    {
      "id": "skill_001199",
      "name": "Pall Surge Blight",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "miasma",
      "geometry_type": "vortex_pull",
      "energy_cost": 21.9,
      "cooldown_seconds": 4.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 5.1,
            "stagger_seconds": 0.5
          }
        }
      ],
      "flavor_text": "A festering pocket of miasma erupts from the cobblestones, hurling the afflicted backward through curtains of choking vapor. The rot lingers where they stood, patient as the city itself."
    },
    {
      "id": "skill_001200",
      "name": "Brine Contagion Arc",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 21.3,
      "cooldown_seconds": 7.1,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.35,
            "duration_seconds": 4.0
          }
        }
      ],
      "flavor_text": "Salt finds every wound the city has forgotten to close. The charge builds in stillwater patience before leaping between bodies like a rumor of plague."
    },
    {
      "id": "skill_001203",
      "name": "Miasmal Seep Surge",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 23.4,
      "cooldown_seconds": 6.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        },
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.22,
            "duration_seconds": 5.0
          }
        }
      ],
      "flavor_text": "Salt-heavy current threads between bodies like rumor, each arc leaving skin pale and slow. The brine remembers every wound it has ever touched."
    },
    {
      "id": "skill_001204",
      "name": "Miasmal Seep Ward",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "self_buff",
      "energy_cost": 18.1,
      "cooldown_seconds": 14.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.3
          }
        }
      ],
      "flavor_text": "Salt crusts over the skin like a second dermis, drawn from the city's own weeping walls. What the brine preserves, the plague cannot claim."
    },
    {
      "id": "skill_001206",
      "name": "Salt Slip Tide",
      "role": "mobility",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "blink",
      "energy_cost": 15.5,
      "cooldown_seconds": 10.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.35,
            "duration_seconds": 8.1
          }
        }
      ],
      "flavor_text": "The body dissolves into brine for a breathless moment, slipping between heartbeats and plague-thick air. What remains is slick, preserved, untouchable \u2014 the city's rot finds no purchase on skin that has briefly ceased to exist."
    }
  ],
