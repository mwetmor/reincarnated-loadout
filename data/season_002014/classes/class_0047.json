{
  "id": "class_0047",
  "name": "Plague Cartographer",
  "title_completion": "a Plague Cartographer",
  "flavor_text": "Armed with chalk and a nose already dead to the smell, you map the spread of sickness through the Plague City's fog-choked alleys \u2014 quarantine lines drawn in white, miasma pooling where your marks dissolve. You are neither healer nor soldier, but something the city needs more: someone who knows where the rot ends and the living begin. Every ward you scrawl is a border; every border, a small act of mercy.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "fire",
  "seasonal_dominant_element": "pitch",
  "is_act_boss": false,
