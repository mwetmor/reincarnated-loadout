  "skills": [
    {
      "id": "skill_000984",
      "name": "Chalk Ward Subsidence",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 20.3,
      "cooldown_seconds": 7.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The pale ground softens and drinks itself down, pulling the sick city's foundations into a slow, white collapse. What was solid remembers it was always powder."
    },
    {
      "id": "skill_001227",
      "name": "Chalk Pall Drift",
      "role": "mobility",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "dash_attack",
      "energy_cost": 16.5,
      "cooldown_seconds": 9.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.8
          }
        }
      ],
      "flavor_text": "The ward dissolves into pale suspension, carrying the caster through infected air before setting like plaster around those left behind. Three heartbeats pass before the dust remembers how to crumble."
    },
    {
      "id": "skill_000986",
      "name": "Brine Seep Totem",
      "role": "damage_over_time",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "circle",
      "energy_cost": 15.73,
      "cooldown_seconds": 7.37,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.25,
            "duration_seconds": 13.2
          }
        }
      ],
      "flavor_text": "A pillar of salt-heavy fog rises from the cracked cobblestones, breathing cold preservation into the air around it. What it touches slows, thickens, begins to cure from the inside out."
    },
    {
      "id": "skill_000987",
      "name": "Chalk Ward Soaking",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "self_buff",
      "energy_cost": 23.7,
      "cooldown_seconds": 9.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.9
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.11,
            "duration_seconds": 8.5
          }
        }
      ],
      "flavor_text": "The chalk drinks deep before it holds, swelling white and dense against whatever comes. For a breath, the body becomes a sealed thing \u2014 soft but unyielding, like a wall that has forgotten how to crumble."
    },
    {
      "id": "skill_000988",
      "name": "Chalk Ward Tide",
      "role": "control",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "vortex_pull",
      "energy_cost": 26.3,
      "cooldown_seconds": 18.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.3
          }
        }
      ],
      "flavor_text": "A pale surge exhales outward from crumbling white hands, dragging the afflicted still as standing water in a sealed courtyard. The city holds its breath, and so do they."
    },
    {
      "id": "skill_000990",
      "name": "Chalk Ward Seep",
      "role": "mobility",
