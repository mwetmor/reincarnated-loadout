{
  "id": "class_0041",
  "name": "Chalk-Handed Quarantine Warden",
  "title_completion": "a Chalk-Handed Quarantine Warden",
  "flavor_text": "Where the Plague City's streets run thick with brine and the miasma curls between cobblestones like a living thing, she draws her wards \u2014 broad white lines across doorframes, gutters, and the foreheads of the already-dying. The chalk never runs out; the city always needs more lines. They say she was an inspector once, in another life, measuring property boundaries no one cares about anymore.",
  "archetype_tag": "earth_controller",
  "energy_type": "mana",
  "role_orientation": "control",
  "range_profile": "long",
