            "percent": 0.22,
            "duration_seconds": 9.9
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.18,
            "duration_seconds": 4.2
          }
        }
      ],
      "flavor_text": "The plague city's black water rises through the skin, feeding thought and hunger in equal measure. For a breath, the mind burns cleaner than it should."
