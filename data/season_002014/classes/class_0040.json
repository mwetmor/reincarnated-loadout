  "skills": [
    {
      "id": "skill_000970",
      "name": "Brine Contagion Arc",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 38.1,
      "cooldown_seconds": 8.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        },
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.46,
            "duration_seconds": 3.3
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.12,
            "duration_seconds": 5.0
          }
        }
      ],
      "flavor_text": "Salt-heavy current leaps from body to body through the plague quarter's wet air, each arc colder and more bitter than the last. Where it passes, flesh slows like meat cured against its will."
    },
    {
      "id": "skill_000973",
      "name": "Pitch Bloom Ring",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 22.6,
      "cooldown_seconds": 5.1,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Black ichor erupts from the cobblestones in a perfect circle, catching all at once in a crown of oily fire. The city's rot feeds the flame, and the flame feeds on everything else."
    },
    {
      "id": "skill_000974",
      "name": "Chalk Ward Rising",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "self_buff",
      "energy_cost": 18.9,
      "cooldown_seconds": 9.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.1
          }
        }
      ],
      "flavor_text": "The city's old quarantine lines remember themselves, chalked boundaries surfacing through the skin like forgotten law. For a breath, nothing that carries death may carry it here."
    },
    {
      "id": "skill_000975",
      "name": "Brine Slip",
      "role": "mobility",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "blink",
      "energy_cost": 17.1,
      "cooldown_seconds": 8.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.21,
            "duration_seconds": 3.5
          }
        }
      ],
      "flavor_text": "Salt-thick air collapses inward where you stood, leaving a rime of frost and the faint sting of preserved things. Whatever you passed through forgets warmth for a moment."
    },
    {
      "id": "skill_000976",
      "name": "Pall Surge Warding",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "self_buff",
      "energy_cost": 19.6,
      "cooldown_seconds": 10.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.6
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.11,
            "duration_seconds": 5.2
          }
        }
      ],
      "flavor_text": "The infected district folds inward as the caster vanishes through a seam of black water, reappearing encased in a slick, adhesive shell that drinks incoming force. Pitch clings to the ward's surface like a second skin, turning the body briefly untouchable."
    },
    {
      "id": "skill_000977",
      "name": "Pitch Bloom Surge",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "single_target",
      "energy_cost": 27.5,
      "cooldown_seconds": 7.8,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Black water rises through the cracked streets, igniting vein by vein as it finds each new host. The city breathes it in, and the fire answers."
    },
    {
      "id": "skill_000978",
      "name": "Pall Surge Draught",
      "role": "burst_damage",
      "canonical_element": "wind",
      "seasonal_element": "miasma",
      "geometry_type": "single_target",
      "energy_cost": 35.7,
      "cooldown_seconds": 7.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "wind"
          }
        },
        {
          "name": "knockback",
          "params": {
            "distance": 3.1,
            "stagger_seconds": 0.6
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.11
          }
        }
      ],
      "flavor_text": "A held breath becomes a weapon — the city's strangled air coils into a single drowning column that tears flesh and feeds the one who releases it. Whatever it touches staggers like a man who has just remembered he is dying."
    },
    {
      "id": "skill_000980",
      "name": "Still Water Ward",
      "role": "defensive",
      "canonical_element": "wind",
      "seasonal_element": "miasma",
      "geometry_type": "self_buff",
      "energy_cost": 20.0,
      "cooldown_seconds": 9.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.1
          }
        }
      ],
      "flavor_text": "The body becomes a sealed vessel, impermeable as standing water in a quarantined well. For a breathless moment, nothing passes through — not blade, not breath, not the city's slow rot."
    },
    {
      "id": "skill_000981",
      "name": "Brine Scatter Bloom",
      "role": "primary_attack",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "multi_projectile",
      "energy_cost": 12.1,
      "cooldown_seconds": 0.9,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "water"
          }
        }
      ],
      "flavor_text": "Salted water erupts outward in a fan of bitter droplets, each one carrying the weight of preserved rot. The city's stagnant air catches them mid-flight, turning a simple gesture into something that stings long after it lands."
    },
    {
      "id": "skill_000982",
      "name": "Pitch Bloom Immersion",
      "role": "utility",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "self_buff",
      "energy_cost": 17.8,
