{
  "id": "class_0040",
  "name": "Plague Apothecary",
  "title_completion": "a Plague Apothecary",
  "flavor_text": "They came to the Plague City to cure it, or perhaps to learn from it — the distinction blurred somewhere between the third ward and the fifth body. Now they carry the brine of the sick canals in their veins and the chalk-dust of quarantine walls on their fingers, brewing contagions that heal as often as they destroy. The miasma does not frighten them; it answers.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "water",
  "seasonal_dominant_element": "brine",
  "is_act_boss": false,
