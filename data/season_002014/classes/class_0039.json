          }
        }
      ],
      "flavor_text": "A ring of soft white sediment erupts from the earth, drawing the plague city's waterlogged ground upward in a crumbling crown that pins the afflicted in place. The chalk remembers every body buried beneath it."
    },
    {
      "id": "skill_000954",
      "name": "Pall Surge Breath",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "miasma",
      "geometry_type": "vortex_pull",
      "energy_cost": 16.5,
      "cooldown_seconds": 7.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "The channeler exhales in slow, deliberate waves, and the harbor fog thickens into something that cuts. Each breath sent outward carries the city's oldest air — the kind that has passed through too many dying lungs to be anything but ruin."
    },
    {
      "id": "skill_000955",
      "name": "Pall Surge Bloom",
      "role": "burst_damage",
      "canonical_element": "wind",
