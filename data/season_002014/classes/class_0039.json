  "skills": [
    {
      "id": "skill_000941",
      "name": "Chalk Spall Tide",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "multi_projectile",
      "energy_cost": 13.1,
      "cooldown_seconds": 0.9,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "Fractured chalk erupts outward in a pale fan, each shard heavy with the city's slow dissolution. The walls remember every crack, and now they share them."
    },
    {
      "id": "skill_000947",
      "name": "Pall Surge Seep",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "miasma",
      "geometry_type": "vortex_pull",
      "energy_cost": 13.3,
      "cooldown_seconds": 6.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 4.6,
            "stagger_seconds": 0.3
          }
        }
      ],
      "flavor_text": "A circle of breathless air opens beneath the feet of the living, exhaling the city's oldest sickness upward in a slow, violet-dark column. Those caught in its bloom are thrown back, lungs full of something that will finish its work long after the pressure fades."
    },
    {
      "id": "skill_000948",
      "name": "Chalk Ward Seeping",
      "role": "sustain",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "single_target",
      "energy_cost": 32.1,
      "cooldown_seconds": 10.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        },
        {
          "name": "heal_over_time",
          "params": {
            "tick_heal": 375,
            "duration_seconds": 7.5
          }
        }
      ],
      "flavor_text": "Soft white dust lifts from crumbling walls and settles into open wounds, each pale mote carrying the city's strange mercy. The body drinks it slowly, mending from the inside out like a house resealing its own cracks."
    },
    {
      "id": "skill_000949",
      "name": "Chalk Ward Settling",
      "role": "damage_over_time",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "totem",
      "energy_cost": 16.4,
      "cooldown_seconds": 7.2,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.8
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The ground beneath the afflicted district remembers every body it has swallowed, and now it refuses to let go. Pale residue rises through the cobblestones, locking feet in place while the earth slowly reclaims what the plague left behind."
    },
    {
      "id": "skill_000950",
      "name": "Miasmal Seep Ward",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "self_buff",
      "energy_cost": 16.6,
      "cooldown_seconds": 8.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.8
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.31,
            "duration_seconds": 7.0
          }
        }
      ],
      "flavor_text": "Brine seeps through every seam of the body, crystallizing at the skin into a bitter carapace that turns aside blade and contagion alike. For a breath, the salt remembers what it means to preserve."
    },
    {
      "id": "skill_000951",
      "name": "Miasmal Seep",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 22.6,
      "cooldown_seconds": 9.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "Brine forces itself through every sealed crack and sutured wound, carrying the city's long memory of rot. What it touches does not simply break — it cures, in the oldest and cruelest sense of the word."
    },
    {
      "id": "skill_000952",
      "name": "Miasmal Seep Tide",
      "role": "area_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "circle",
      "energy_cost": 27.0,
      "cooldown_seconds": 6.8,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "water"
          }
        },
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.26,
            "duration_seconds": 4.9
          }
        }
      ],
      "flavor_text": "Brine wells up through the cracked cobblestones in a slow, bitter circle, salting the wound of every soul caught within its reach. The cold does not rush — it preserves."
    },
    {
      "id": "skill_000953",
      "name": "Chalk Ward Tide",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "chalk",
      "geometry_type": "ground_targeted_circle",
