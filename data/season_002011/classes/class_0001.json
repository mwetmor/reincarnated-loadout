{
  "id": "class_0001",
  "name": "Brine-Soaked Border Mage",
  "title_completion": "a Brine-Soaked Border Mage",
  "flavor_text": "They say the Wall was built to keep things out, but you've learned it's better used to keep things in — suspended, saturated, and slowly dissolving in saltwater hexes. You stamp the air like a customs form and the world obeys, held at the checkpoint between what is permitted and what seeps through anyway. Your magic smells like low tide and contraband pitch, and the guards on both sides have learned not to ask questions.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "fire",
  "seasonal_dominant_element": "pitch",
  "is_act_boss": false,
