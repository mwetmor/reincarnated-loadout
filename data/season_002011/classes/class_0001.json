  "skills": [
    {
      "id": "skill_000001",
      "name": "Brine Marked Crossing",
      "role": "utility",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "self_buff",
      "energy_cost": 14.2,
      "cooldown_seconds": 15.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.3,
            "duration_seconds": 6.2
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.13,
            "duration_seconds": 7.9
          }
        }
      ],
      "flavor_text": "Salt crusts the skin like a second document, and the body moves with the quiet authority of someone who has already paid every toll. For a breath, the border is yours."
    },
    {
      "id": "skill_000002",
      "name": "Brine Crossing Surge",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 31.6,
      "cooldown_seconds": 9.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "Salt-heavy water leaps from hand to hand along the wall, tracing every hidden route at once. What the border cannot hold, the tide remembers."
    },
    {
      "id": "skill_000003",
      "name": "Checkpoint Hold",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "self_buff",
      "energy_cost": 18.8,
      "cooldown_seconds": 11.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.1
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.35,
            "duration_seconds": 5.4
          }
        }
      ],
      "flavor_text": "The wall breathes iron and stops time at the crossing — for one suspended moment, nothing passes that you do not allow. The earth itself becomes your authority."
    },
    {
      "id": "skill_000004",
      "name": "Brine Crossing Volley",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 29.8,
      "cooldown_seconds": 7.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        },
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.33,
            "duration_seconds": 4.1
          }
        }
      ],
      "flavor_text": "Salt-heavy water bursts from the wall's shadow in a punishing spread, each droplet carrying the bitter cold of things preserved too long in the wrong place. Those caught in its path slow, stiffened by the sting of a border that remembers every crossing."
    },
    {
      "id": "skill_000006",
      "name": "Brine Toll Strike",
      "role": "area_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "circle",
      "energy_cost": 15.1,
      "cooldown_seconds": 5.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "Salt water rises in a punishing circle, wrung from the earth at the checkpoint like contraband seized and crushed. Those caught within it taste the bitter cost of crossing."
    },
    {
      "id": "skill_000007",
      "name": "Toll Strike Contraband",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "single_target",
      "energy_cost": 36.2,
      "cooldown_seconds": 6.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "At the checkpoint, the earth remembers every unpaid debt — fissures crack open beneath those who thought they could pass unseen, swallowing them in the wall's dark reckoning. Wisdom knows where the ground is hungriest."
    },
    {
      "id": "skill_000008",
      "name": "Smuggled Transit Brine",
      "role": "mobility",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "blink",
      "energy_cost": 16.3,
      "cooldown_seconds": 9.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.41,
            "duration_seconds": 2.3
          }
        }
      ],
      "flavor_text": "A traveler vanishes through the salt-crusted wall, reappearing somewhere the guards forgot to watch. The cold that clings to them afterward is the border's way of remembering."
    },
    {
      "id": "skill_000012",
      "name": "Checkpoint Hold",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "multi_projectile",
      "energy_cost": 7.2,
      "cooldown_seconds": 1.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 4.0
          }
        }
      ],
      "flavor_text": "The earth rises like a barricade at the border, seizing the target in packed iron soil that refuses to yield. Nothing moves until the wall decides otherwise."
    },
    {
      "id": "skill_000013",
      "name": "Checkpoint Hold",
      "role": "damage_over_time",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "totem",
      "energy_cost": 20.1,
      "cooldown_seconds": 4.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 1.9
          }
        }
      ],
      "flavor_text": "The border's iron will closes around the target like a gate that has not opened in years. Roots of compacted earth and cold rebar hold them fast while the crossing exacts its slow toll."
    },
    {
      "id": "skill_000014",
      "name": "Crossing Surge Passage",
      "role": "mobility",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "self_buff",
      "energy_cost": 16.7,
      "cooldown_seconds": 8.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.21,
            "duration_seconds": 6.5
          }
        }
      ],
      "flavor_text": "A body learns the wall's blind spots before the mind does — one moment here, the next already through, the iron logic of borders briefly outpaced. For 6.5 seconds the crossing stays open, each step landing where eyes aren't."
    }
  ],
