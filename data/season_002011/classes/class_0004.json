  "skills": [
    {
      "id": "skill_000043",
      "name": "Contraband Ignition",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 12.0,
      "cooldown_seconds": 7.8,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 4.0
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "A slick circle of pitch blooms across the ground, seeping through every crack in the earth like something that was never supposed to cross. It catches without warning, and it does not stop burning until it has taken what it came for."
    },
    {
      "id": "skill_000044",
      "name": "Toll Strike Burial",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "single_target",
      "energy_cost": 28.4,
      "cooldown_seconds": 7.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.8
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.24,
            "duration_seconds": 4.7
          }
        }
      ],
      "flavor_text": "The wall's iron debt collects in full \u2014 a crushing column of dark earth erupts beneath the target, pinning them to the ground like contraband seized at the crossing. For a breathless moment, every wound they carry opens wider."
    },
    {
      "id": "skill_000047",
      "name": "Crossing Surge Pall",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 17.7,
      "cooldown_seconds": 7.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 5.0,
            "stagger_seconds": 0.6
          }
        }
      ],
      "flavor_text": "The earth beneath the wall's shadow convulses, exhaling a dark tide that sweeps trespassers from their footing. What crosses uninvited is not welcomed \u2014 it is expelled."
    },
    {
      "id": "skill_000048",
      "name": "Checkpoint Hold",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "self_buff",
      "energy_cost": 22.6,
      "cooldown_seconds": 8.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.3
          }
        }
      ],
      "flavor_text": "The wall breathes pitch into the space around you, thick and absolute, sealing every crack before the blow can find one. For a moment, nothing crosses."
    },
    {
      "id": "skill_000049",
      "name": "Smuggled Transit Pall",
      "role": "utility",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "self_buff",
      "energy_cost": 14.2,
      "cooldown_seconds": 19.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.15,
            "duration_seconds": 4.7
          }
        }
      ],
      "flavor_text": "Something passes through unseen, pressed flat against the cold stone of the wall \u2014 a shadow carrying weight that customs never catalogued. For a breath, what strikes from the darkness strikes harder."
    },
    {
      "id": "skill_000052",
      "name": "Crossing Surge Pall",
      "role": "primary_attack",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "multi_projectile",
      "energy_cost": 10.9,
      "cooldown_seconds": 1.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "wind"
          }
        },
        {
          "name": "knockback",
          "params": {
            "distance": 6.1,
            "stagger_seconds": 0.6
          }
        }
      ],
      "flavor_text": "A shroud of deathly wind tears through the border like a body thrown across the wall, leaving only the hollow sound of the crossing behind. What passes through does not pass clean."
    },
    {
      "id": "skill_000053",
      "name": "Checkpoint Hold",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 27.2,
      "cooldown_seconds": 4.9,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The earth splits at the crossing, iron-dark fissures branching like a warden's outstretched hands. Nothing passes without paying the toll the ground demands."
    },
    {
      "id": "skill_000055",
      "name": "Crossing Surge Pall",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 21.6,
      "cooldown_seconds": 3.9,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "A shroud of displaced air tears open along the border ground, dark and breathless as a smuggler's last crossing. Everything caught within is swallowed by the surge."
    },
    {
      "id": "skill_000056",
      "name": "Toll Strike Contraband",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "single_target",
      "energy_cost": 21.4,
      "cooldown_seconds": 7.8,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.1,
            "duration_seconds": 8.5
          }
        }
      ],
      "flavor_text": "The ground remembers every weight pressed against it \u2014 at the checkpoint, the earth collects what is owed in a single crushing circle. Those caught within feel the debt of passage settle into their bones."
    }
