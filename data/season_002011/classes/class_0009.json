  "skills": [
    {
      "id": "skill_000214",
      "name": "Contraband Ignition",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 14.4,
      "cooldown_seconds": 7.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 4.5
          }
        }
      ],
      "flavor_text": "Pitch seeps through the cracks in the wall's foundation, pooling black and hungry where no inspector dares to look. What was smuggled through now burns from underneath, patient and absolute."
    },
    {
      "id": "skill_000215",
      "name": "Contraband Ignition",
      "role": "primary_attack",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "multi_projectile",
      "energy_cost": 9.7,
      "cooldown_seconds": 0.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "A bolt of smuggled fire, black and reeking of pitch, punches through at the checkpoint where nothing is supposed to pass. The Wall remembers every crossing."
    },
    {
      "id": "skill_000216",
      "name": "Smuggled Transit Blink",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "self_buff",
      "energy_cost": 19.6,
