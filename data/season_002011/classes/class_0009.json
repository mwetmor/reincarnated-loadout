            "duration_seconds": 4.4
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.21,
            "duration_seconds": 4.8
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.34,
            "duration_seconds": 6.0
          }
        }
      ],
      "flavor_text": "A body moves through the Wall like contraband through a loose stone \u2014 unseen, untaxed, arriving whole on the other side. The pitch clings to the air where you stood, a decoy shadow hardening into a shield no inspector dares touch."
    },
    {
      "id": "skill_000217",
      "name": "Contraband Ignition Sweep",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 16.7,
      "cooldown_seconds": 7.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 4.2
          }
        }
      ],
      "flavor_text": "Pitch smuggled through the wall's blind spots ignites in a single breathless moment, rolling forward in a blackened fan of fire and clinging smoke. What it touches, it keeps burning \u2014 slow and deliberate, like a secret that refuses to stay buried."
    },
    {
      "id": "skill_000218",
      "name": "Contraband Ignition Surge",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "single_target",
      "energy_cost": 38.5,
      "cooldown_seconds": 6.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Pitch smuggled through the Wall's blind spots erupts outward in a spreading fan of black fire, consuming everything the checkpoint was built to stop. The heat reads as declared, but the damage is anything but."
    },
    {
      "id": "skill_000220",
      "name": "Contraband Ignition Ring",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 23.6,
