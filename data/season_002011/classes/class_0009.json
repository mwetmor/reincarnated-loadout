      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 5.0
          }
        }
      ],
      "flavor_text": "A circle of smuggled pitch erupts at the wall's edge, black and hungry, marking everything within its radius as forfeit. The tar clings and burns long after the border has been crossed."
    },
    {
      "id": "skill_000221",
      "name": "Contraband Ignition Run",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 26.5,
      "cooldown_seconds": 4.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Pitch leaps from body to body along the wall's blind corridor, each contact erupting in a chain of fire that no checkpoint was built to stop. The border holds nothing when the smuggled flame already knows the route."
    },
    {
      "id": "skill_000222",
      "name": "Contraband Ignition Totem",
      "role": "utility",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "self_buff",
      "energy_cost": 13.8,
      "cooldown_seconds": 17.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.32,
            "duration_seconds": 5.1
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.19,
            "duration_seconds": 8.1
          }
        }
      ],
      "flavor_text": "A column of pitch-black resin erupts from the earth at the border's edge, seething with smuggled energy that sharpens the mind and replenishes what the crossing cost. Those who pass through its heat leave faster and hungrier than they arrived."
    },
    {
      "id": "skill_000223",
      "name": "Smuggled Transit Pitch",
      "role": "mobility",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "teleport",
      "energy_cost": 11.7,
      "cooldown_seconds": 11.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "A runner learns to move like contraband \u2014 low, black, and unseen until the moment of crossing. The pitch clings where you were, burning a false trail for those who would hold the line."
    },
    {
      "id": "skill_000224",
      "name": "Checkpoint Hold",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "self_buff",
      "energy_cost": 24.1,
      "cooldown_seconds": 12.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.6
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.21,
            "duration_seconds": 9.4
          }
        }
      ],
      "flavor_text": "Pitch seals the crossing point like a stamped denial, thick and absolute \u2014 nothing passes that has not been cleared. The body learns to slip sideways through scrutiny, moving where the wall's gaze does not fall."
    }
