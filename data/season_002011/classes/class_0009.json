{
  "id": "class_0009",
  "name": "Pitch Smuggler",
  "title_completion": "a Pitch Smuggler",
  "flavor_text": "They said nothing burns hotter than contraband pitch pushed through a border wall at midnight. You disagreed \u2014 and lit the checkpoint to prove it. Now you slip between crossings like smoke through iron bars, trailing fire that no manifest ever declared.",
