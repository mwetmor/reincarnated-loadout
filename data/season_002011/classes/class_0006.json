  "skills": [
    {
      "id": "skill_000261",
      "name": "Declared Passage Dash",
      "role": "mobility",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "dash_attack",
      "energy_cost": 17.0,
      "cooldown_seconds": 9.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.27,
            "duration_seconds": 5.0
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "A pilgrim steps through the checkpoint's blinding scrutiny and emerges untouchable, blessed by the harsh light of official sanction. For one breathless moment, nothing illegal can touch what has been declared clean."
    },
    {
      "id": "skill_000133",
      "name": "Checkpoint Hold Signal",
      "role": "control",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 21.4,
      "cooldown_seconds": 19.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.8
          }
        }
      ],
      "flavor_text": "A ring of earthen authority erupts at the border, sealing every tongue mid-word as if papers have been found wanting. The silence is not absence \u2014 it is the weight of a gate that will not open."
    },
    {
      "id": "skill_000134",
      "name": "Declared Passage Lockdown",
      "role": "control",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 28.4,
      "cooldown_seconds": 8.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.7
          }
        }
      ],
      "flavor_text": "At the border's threshold, light pools into a binding circle \u2014 every voice caught within it is stamped, held, and made silent. No word crosses without permission."
    },
    {
      "id": "skill_000135",
      "name": "Declared Passage Ground",
      "role": "damage_over_time",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 18.6,
      "cooldown_seconds": 7.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "consecrate",
          "params": {
            "zone_duration_seconds": 6.7,
            "dot_tick_damage": 750,
            "heal_amplification_percent": 0.15
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "Where the earth is stamped and sanctioned, holy light seeps through the cracks like contraband that cannot be stopped. The zone burns with the slow authority of something officially denied yet undeniably present."
    },
    {
      "id": "skill_000136",
      "name": "Declared Passage Totem",
      "role": "utility",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 16.1,
      "cooldown_seconds": 17.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.24,
            "duration_seconds": 8.7
          }
        }
      ],
      "flavor_text": "A pillar of violet light erupts from the earth at the border's edge, its radiance sanctioning every blow that passes through. For a breathless moment, the wall itself seems to bless the crossing."
    },
    {
      "id": "skill_000137",
      "name": "Declared Passage Fork",
      "role": "area_damage",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 24.97,
      "cooldown_seconds": 4.73,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "holy"
          }
        },
        {
          "name": "consecrate",
          "params": {
            "zone_duration_seconds": 5.5,
            "dot_tick_damage": 750,
            "heal_amplification_percent": 0.14
          }
        }
      ],
      "flavor_text": "At the wall's threshold, light splits into twin columns of sanctioned radiance, searing the ground with holy authority. The consecrated earth smolders where it touched, as if the border itself has been stamped and sealed."
    }
  ],
