{
  "id": "class_0006",
  "name": "Border Canoness",
  "title_completion": "a Border Canoness",
  "flavor_text": "She does not guard the wall \u2014 she *is* the wall, her edicts made manifest in blinding columns of sanctioned light. Every soul that passes does so because she willed it, and every soul that doesn't is held in radiant suspension until she decides otherwise. The checkpoint is not a place. It is her.",
  "archetype_tag": "holy_controller",
  "energy_type": "mana",
  "role_orientation": "control",
  "range_profile": "long",
  "dominant_element": "holy",
  "seasonal_dominant_element": null,
  "is_act_boss": false,
