  "skills": [
    {
      "id": "skill_000209",
      "name": "Toll Strike",
      "role": "primary_attack",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "melee_strike",
      "energy_cost": 30.91,
      "cooldown_seconds": 1.54,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1056,
            "element": "physical"
          }
        }
      ],
      "flavor_text": "Every crossing demands its price, paid in the language of stone and force. The wall remembers every blow that has ever tested it."
    },
    {
      "id": "skill_000210",
      "name": "Toll Strike Lockdown",
      "role": "control",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 37.5,
      "cooldown_seconds": 8.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.2
          }
        }
      ],
      "flavor_text": "A crushing blow lands like a border checkpoint slamming shut \u2014 the target's voice dies in their throat, swallowed by stone and bureaucratic silence. Nothing passes through here without permission."
    },
    {
      "id": "skill_000211",
      "name": "Toll Strike Lockdown",
      "role": "control",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 35.0,
      "cooldown_seconds": 11.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.5
          }
        }
      ],
      "flavor_text": "The checkpoint slams shut in a ring of compacted earth, and every voice caught within goes dead \u2014 swallowed by the wall's indifferent weight. Nothing crosses, nothing calls out, until the dust decides otherwise."
    },
    {
      "id": "skill_000271",
      "name": "Toll Strike Crossing",
      "role": "control",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 32.6,
      "cooldown_seconds": 13.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.1
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "physical"
          }
        }
      ],
      "flavor_text": "The earth buckles at the checkpoint, a wordless authority that stops movement cold. Those caught beneath it find their voices seized before their feet."
    },
    {
      "id": "skill_000213",
      "name": "Toll Strike Levy",
      "role": "utility",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 42.7,
      "cooldown_seconds": 19.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.28,
            "duration_seconds": 6.1
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.4
          }
        }
      ],
      "flavor_text": "A crushing blow lands at the threshold, shaking the ground beneath the target's feet and sealing their voice behind an invisible wall of enforced silence. The earth remembers every toll unpaid."
    }
