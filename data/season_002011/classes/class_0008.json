{
  "id": "class_0008",
  "name": "Wall Warden",
  "title_completion": "a Wall Warden",
  "flavor_text": "Every soul that crosses owes a toll, and you are the one who collects it \u2014 in bruises, in broken pride, in bodies pressed into iron and pitch. You were not reincarnated with a weapon; you were reincarnated as the wall itself, fists like checkpoint gates that slam shut on anyone foolish enough to rush through. Rage is your tariff, and no one passes without paying.",
  "archetype_tag": "physical_grappler",
  "energy_type": "rage",
  "role_orientation": "control",
  "range_profile": "close",
  "dominant_element": "physical",
  "seasonal_dominant_element": null,
