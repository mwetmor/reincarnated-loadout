{
  "id": "class_0002",
  "name": "Saltwater Hexbrigand",
  "title_completion": "a Saltwater Hexbrigand",
  "flavor_text": "Where the wall meets the tide, contraband flows like brine through cracked iron \u2014 and so does her magic. She deals in cursed totems, surge-borne pallclouds, and checkpoint spells that hold travelers in place just long enough to toll them twice. Every border is a transaction, and she has never once paid her own way through.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "water",
  "seasonal_dominant_element": "brine",
  "is_act_boss": true,
