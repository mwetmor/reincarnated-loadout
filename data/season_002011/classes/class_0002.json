  "skills": [
    {
      "id": "skill_000015",
      "name": "Crossing Surge Hold",
      "role": "mobility",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "dash_attack",
      "energy_cost": 19.3,
      "cooldown_seconds": 6.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.0
          }
        }
      ],
      "flavor_text": "The body tears through the checkpoint in a breath, but the earth remembers the crossing and clamps down, rooting both mover and ground in a moment of iron refusal. What passes through the wall does not pass freely."
    },
    {
      "id": "skill_000016",
      "name": "Contraband Ignition Totem",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 19.5,
      "cooldown_seconds": 6.4,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 375,
            "duration_seconds": 13.4
          }
        }
      ],
      "flavor_text": "A slick column of pitch rises unbidden from the earth, seeping through the cracks where no inspector looks. It burns slow and deliberate, the kind of fire that knows how to wait."
    },
    {
      "id": "skill_000017",
      "name": "Toll Strike Contraband",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "single_target",
      "energy_cost": 36.9,
      "cooldown_seconds": 7.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "Iron teeth of the checkpoint bite through flesh and stone alike, a chain of crushing earth-weight passing from body to body like a smuggled debt finally collected. The wall remembers every soul that tried to cross without paying."
    },
    {
      "id": "skill_000018",
      "name": "Checkpoint Hold Volley",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "single_target",
      "energy_cost": 31.6,
      "cooldown_seconds": 8.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "At the wall's edge, the earth itself is interrogated \u2014 stones wrenched from the border's foundation gather into a dense, trembling mass before erupting outward in a punishing barrage. Each fragment carries the weight of every crossing denied, every toll unpaid."
    },
    {
      "id": "skill_000021",
      "name": "Crossing Surge Pall",
      "role": "primary_attack",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "multi_projectile",
      "energy_cost": 10.5,
      "cooldown_seconds": 0.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "wind"
          }
        },
        {
          "name": "knockback",
          "params": {
            "distance": 7.0,
            "stagger_seconds": 0.5
          }
        }
      ],
      "flavor_text": "A shroud of wind tears through the border crossing like something desperate and unseen, scattering everything that dares hold its ground. The dark current asks no permission and waits for no checkpoint."
    },
    {
      "id": "skill_000022",
      "name": "Crossing Surge Pall",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 26.0,
      "cooldown_seconds": 5.1,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        },
        {
          "name": "knockback",
          "params": {
            "distance": 4.0,
            "stagger_seconds": 0.4
          }
        }
      ],
      "flavor_text": "A shroud of wind tears through the border crossing in chained bursts, scattering bodies like contraband flung from an overturned cart. The air goes dead and dark between each crack of displaced force."
    },
    {
      "id": "skill_000024",
      "name": "Contraband Ignition Ring",
      "role": "utility",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "self_buff",
      "energy_cost": 14.0,
      "cooldown_seconds": 18.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.32,
            "duration_seconds": 6.1
          }
        }
      ],
      "flavor_text": "Pitch seeps up through the checkpoint cracks in a perfect circle, catching light no inspector was meant to see. For a breathless moment, everything that crosses its boundary hits harder than it has any right to."
    },
    {
      "id": "skill_000025",
      "name": "Contraband Ignition Barrage",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "pitch",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 27.6,
      "cooldown_seconds": 7.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Fistfuls of pitch-black contraband arc over the checkpoint wall in a slow, deliberate volley, each mass hitting the earth with a wet, adhesive slap before blooming into roaring fire. The border holds nothing back once the ground itself starts burning."
    },
    {
      "id": "skill_000026",
      "name": "Checkpoint Hold",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "self_buff",
      "energy_cost": 17.4,
      "cooldown_seconds": 12.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.5
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.3,
            "duration_seconds": 4.3
          }
        }
      ],
      "flavor_text": "The wall becomes you \u2014 iron pressed into skin, breath held at the threshold while the world's weight finds nothing to grip. For a moment, you are the border itself, unmoved and unreadable."
    },
    {
      "id": "skill_000027",
      "name": "Crossing Surge Pall",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 22.3,
      "cooldown_seconds": 4.8,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 7.8,
            "stagger_seconds": 0.9
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "A totem erupts at the border's edge, exhaling a dark wind that tears through everything caught between here and the other side. Those who linger are flung back, breathless, as if the wall itself refused their crossing."
    }
  ],
