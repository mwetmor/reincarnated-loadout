  "skills": [
    {
      "id": "skill_000028",
      "name": "Crossing Surge Pall",
      "role": "burst_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "single_target",
      "energy_cost": 21.5,
      "cooldown_seconds": 4.3,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "A forked shroud of wind tears through the border crossing like contraband breath held too long — dark, desperate, and sudden. Those caught in its split path find no checkpoint waits on the other side."
    },
    {
      "id": "skill_000029",
      "name": "Checkpoint Hold",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "self_buff",
      "energy_cost": 17.6,
      "cooldown_seconds": 11.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.6
          }
        }
      ],
      "flavor_text": "The wall does not argue — it simply refuses. Salt-crusted and unyielding, this barrier drinks momentum whole, preserving what stands behind it in bitter stillness."
    },
    {
      "id": "skill_000030",
      "name": "Gravel Toll Strike",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "multi_projectile",
      "energy_cost": 9.8,
      "cooldown_seconds": 0.7,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "A volley of dense stone shards tears through the checkpoint like contraband forced through a gap in the wall. The earth does not ask permission — it simply collects what it is owed."
    },
    {
      "id": "skill_000034",
      "name": "Toll Strike Burial",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 28.1,
      "cooldown_seconds": 6.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 1.7
          }
        }
      ],
      "flavor_text": "The wall breathes iron into the earth and the ground answers — fissures crack outward in a dark fan, pinning those who cross where they stand. No passage is free here."
    },
    {
      "id": "skill_000035",
      "name": "Brine Crossing Surge",
      "role": "area_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "circle",
      "energy_cost": 28.1,
      "cooldown_seconds": 4.7,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "water"
          }
        }
      ],
      "flavor_text": "Salt water finds every crack in the wall, leaping from body to body like contraband passed hand to hand in the dark. What the border cannot stop, the tide carries through."
    },
    {
      "id": "skill_000037",
      "name": "Brine Crossing Surge",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 36.6,
      "cooldown_seconds": 7.7,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.12,
            "duration_seconds": 9.8
          }
        }
      ],
      "flavor_text": "Salt water finds every crack in the wall, leaping from body to body in bitter arcs that leave the skin raw and the contraband glowing. What crosses the border carries the sting of everything it touched along the way."
    },
    {
      "id": "skill_000038",
      "name": "Crossing Surge Pall",
      "role": "sustain",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "single_target",
      "energy_cost": 34.2,
      "cooldown_seconds": 9.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.23,
            "duration_seconds": 9.6
          }
        }
      ],
      "flavor_text": "A shrouded mending flows through the one who dares the wall's shadow, knitting wounds with the dark certainty of those who cross unseen. The body remembers how to endure, and the mind's reserves quietly refill like breath held and finally released."
    },
    {
      "id": "skill_000039",
      "name": "Brined Crossing Surge",
      "role": "damage_over_time",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "circle",
      "energy_cost": 10.6,
      "cooldown_seconds": 7.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.25,
            "duration_seconds": 2.4
          }
        }
      ],
      "flavor_text": "Salt works its way into every crack, slowing the body like contraband held too long at the wall. The bitter preserving cold seeps through flesh, patient as a border that never forgets."
    },
    {
      "id": "skill_000040",
      "name": "Checkpoint Hold",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "iron",
      "geometry_type": "self_buff",
      "energy_cost": 17.4,
      "cooldown_seconds": 9.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.8
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.28,
            "duration_seconds": 5.6
          }
        }
      ],
      "flavor_text": "The wall becomes you — iron-dense and unyielding, your body reads every approach before it arrives. Nothing crosses without your knowing."
    },
    {
      "id": "skill_000042",
      "name": "Crossing Surge Pall",
      "role": "damage_over_time",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 13.4,
      "cooldown_seconds": 7.9,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "knockback",
          "params": {
            "distance": 7.3,
            "stagger_seconds": 0.4
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "A deathly column erupts at the wall's threshold, dragging contraband wind through the dark between checkpoints. Those caught in its shroud are flung back across the border they dared to cross."
    }
