{
  "id": "class_0003",
  "name": "Brinewall Toll Mage",
  "title_completion": "a Brinewall Toll Mage",
  "flavor_text": "At the border wall, every crossing has a price — and she is the one who collects it, in salt and iron and slow-seeping tide. Her spells don't strike so much as saturate, soaking through armour like brine through cracked stone, leaving enemies waterlogged and heavy-footed long after the initial surge. They say she was a customs inspector in her last life; now she inspects the threshold between living and dying.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "earth",
  "seasonal_dominant_element": "iron",
  "is_act_boss": true,
