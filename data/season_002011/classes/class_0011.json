            "tick_heal": 375,
            "duration_seconds": 8.8
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.24,
            "duration_seconds": 9.5
          }
        }
      ],
      "flavor_text": "Salt seeps through every crack in the wall, carrying with it a bitter nourishment that mends flesh and steadies the mind. What the border preserves, it also sustains."
    },
    {
      "id": "skill_000235",
      "name": "Brine Toll Strike",
      "role": "primary_attack",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "multi_projectile",
      "energy_cost": 7.3,
      "cooldown_seconds": 0.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "water"
          }
        }
      ],
      "flavor_text": "A concentrated surge of salt-heavy water crashes against a single target like a smuggler's debt come due. The sting lingers long after the blow, preserving the wound in bitter memory."
    },
    {
      "id": "skill_000236",
      "name": "Brine Marker Post",
      "role": "damage_over_time",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "circle",
      "energy_cost": 14.4,
      "cooldown_seconds": 6.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.25,
            "duration_seconds": 18.7
          }
        }
      ],
      "flavor_text": "A squat column of salt-crusted earth erupts at the border's edge, weeping mineral tears into the soil beneath those who linger too long. The ground remembers every crossing, and it is not forgiving."
    },
    {
      "id": "skill_000237",
      "name": "Brine Sealed Crossing",
      "role": "sustain",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 27.6,
      "cooldown_seconds": 5.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.11,
            "duration_seconds": 9.0
          }
        }
      ],
      "flavor_text": "Salt pressed into the wound holds more than it stings \u2014 it preserves what remains, drawing the body back from the threshold with bitter, stubborn care. The mana flows steady after, like contraband finding its route through familiar walls."
    },
    {
      "id": "skill_000238",
