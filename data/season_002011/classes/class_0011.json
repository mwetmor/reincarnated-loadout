          }
        }
      ],
      "flavor_text": "Salt water bleeds through the cracked wall in slow, relentless rings, stinging everything it touches into stillness. What crosses this threshold carries the border's bitterness long after it passes."
    },
    {
      "id": "skill_000240",
      "name": "Brine Checkpoint Bloom",
      "role": "sustain",
      "canonical_element": "water",
      "seasonal_element": "brine",
