          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.4
          }
        }
      ],
      "flavor_text": "Iron-dark shards of the Wall itself tear loose and scatter outward in a crushing arc, pinning those caught beneath their weight to the cracked earth. The border does not ask twice."
    },
    {
      "id": "skill_000140",
      "name": "Pall Crossing Surge",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
