      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "A shroud of deathly wind tears through the border in cascading waves, each gust carrying the cold breath of those who never made it across. The channel holds open just long enough for the storm to do what walls cannot stop."
    },
    {
      "id": "skill_000144",
