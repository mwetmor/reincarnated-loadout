            "duration_seconds": 3.2
          }
        }
      ],
      "flavor_text": "Pitch-black resin seeps through the cracks of the wall, coating the hands in silence and purpose. What crosses unspoken carries the heaviest toll."
    },
    {
      "id": "skill_000145",
      "name": "Checkpoint Hold Pall",
      "role": "defensive",
      "canonical_element": "wind",
      "seasonal_element": "pall",
