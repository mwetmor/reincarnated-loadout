{
  "id": "class_0036",
  "name": "Seam Witch",
  "title_completion": "a Seam Witch",
  "flavor_text": "Deep in the drowned halls where the dwarves once carved fire from stone, she learned to read the pressure trapped inside the coal \u2014 the last breath of ancient heat, still waiting to give way. She does not conjure flame so much as coax it loose, standing perfectly still while the mountain does the burning for her. The brine has seeped into everything here, but some seams, she knows, run too hot and too deep for the water to ever truly reach.",
  "archetype_tag": "fire_mage",
  "energy_type": "mana",
  "role_orientation": "damage",
  "range_profile": "medium",
  "dominant_element": "fire",
  "seasonal_dominant_element": "coal",
