  "skills": [
    {
      "id": "skill_000857",
      "name": "Load-Bearing Stillness",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "self_buff",
      "energy_cost": 21.6,
      "cooldown_seconds": 13.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.3
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.3,
            "duration_seconds": 5.3
          }
        }
      ],
      "flavor_text": "The old stone remembers how to hold. Pressure gathers inward, dense and unyielding, the way a support pillar drinks the weight of a mountain and does not speak of it."
    },
    {
      "id": "skill_000858",
      "name": "Seam Pressure Pickfall",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "single_target",
      "energy_cost": 21.7,
      "cooldown_seconds": 6.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "A bolt of compressed fire erupts from the rock face and caroms through the hollow dark, finding every wall the dwarves left standing. It carries the memory of a forge that no longer breathes."
    },
    {
      "id": "skill_000859",
      "name": "Seam Pressure Surge",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "single_target",
      "energy_cost": 27.5,
      "cooldown_seconds": 7.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 5.4
          }
        }
      ],
      "flavor_text": "Deep in the abandoned shafts, heat finds the cracks it was always meant to follow \u2014 leaping vein to vein through stone that remembers the forge. The coal does not burn so much as finally confess."
    },
    {
      "id": "skill_000860",
      "name": "Withdrawal Soot Rising",
      "role": "utility",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "self_buff",
      "energy_cost": 19.8,
      "cooldown_seconds": 18.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.17,
            "duration_seconds": 6.9
          }
        }
      ],
      "flavor_text": "In the abandoned shafts where forge-smoke still clings to wet stone, something remembers how to strike. The darkness here does not swallow \u2014 it sharpens."
    },
    {
      "id": "skill_000861",
      "name": "Seam Pressure Remembrance",
