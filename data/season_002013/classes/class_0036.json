      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 7.0
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Where dwarven forges once breathed, the stone still holds their heat \u2014 a slow, pressurized burn that seeps upward through cracked rock and forgotten coal veins. The ground does not explode; it exhales."
    },
    {
