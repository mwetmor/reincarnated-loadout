{
  "id": "class_0031",
  "name": "Brine-Soaked Pit Sage",
  "title_completion": "a Brine-Soaked Pit Sage",
  "flavor_text": "The old mines remember everything \u2014 the weight of stone, the patience of salt, the slow grief of water finding its way in. You did not choose these halls; the halls chose what was left of you, filling your hollow places with brine and old pressure until something new hardened in the dark. Now you speak in shaft echoes and pickfall rhythms, and the seams open for you like a question finally answered.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "wind",
  "seasonal_dominant_element": "pall",
