  "skills": [
    {
      "id": "skill_000647",
      "name": "Load-Bearing Stillness",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "self_buff",
      "energy_cost": 24.9,
      "cooldown_seconds": 14.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.7
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.14,
            "duration_seconds": 8.6
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.29,
            "duration_seconds": 7.5
          }
        }
      ],
      "flavor_text": "The water finds every crack, but the old stone remembers how to hold. Something in the deep dark braces itself against the weight of what is coming."
    },
    {
      "id": "skill_000648",
      "name": "Brine Seeps Through",
      "role": "sustain",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 27.3,
      "cooldown_seconds": 11.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        }
      ],
      "flavor_text": "Salt finds every crack in stone, and so does the will to endure \u2014 it fills the wounded places with something ancient and preserving. The empty halls taught stillness; the body learns to hold."
    },
    {
      "id": "skill_000650",
      "name": "Brine Pickfall Surge",
      "role": "burst_damage",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "single_target",
      "energy_cost": 34.7,
      "cooldown_seconds": 6.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "water"
          }
        },
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.18,
            "duration_seconds": 7.6
          }
        }
      ],
      "flavor_text": "Salt-heavy water hammers down in a scatter of bitter shards, each one carrying the sting of preserved grief. The empty halls remember every blow, and for a breath after, so does the stone."
    },
    {
      "id": "skill_000652",
      "name": "Pickfall Remembrance",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "single_target",
      "energy_cost": 20.3,
      "cooldown_seconds": 9.6,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The halls hold their breath as pressure builds in the dark \u2014 then the floor gives all at once, and the stone remembers every blow ever struck against it. What was patient becomes catastrophic."
    },
    {
      "id": "skill_000654",
      "name": "Brine Ring Hush",
      "role": "utility",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "circle",
      "energy_cost": 15.5,
      "cooldown_seconds": 14.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.29,
            "duration_seconds": 8.1
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.5
          }
        }
      ],
      "flavor_text": "Salt crystallizes in a perfect circle where dwarven voices once carried through stone, and everything caught inside it sharpens into bitter, wordless clarity. The preserved silence of empty halls presses outward, and those within strike harder for having nothing left to say."
    },
    {
      "id": "skill_000655",
      "name": "Seam Pressure Bloom",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 18.3,
      "cooldown_seconds": 6.1,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "The old coal seams remember what it meant to burn, and under patient hands they remember all at once. Heat gathers in the flooded dark until the water itself has nowhere left to go."
    },
    {
      "id": "skill_000657",
      "name": "Pickfall Seam Fork",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "multi_projectile",
      "energy_cost": 5.0,
      "cooldown_seconds": 0.0,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.1
          }
        }
      ],
      "flavor_text": "The blow lands where the rock remembers breaking, splitting into two ruthless lines of force that pin the earth and everything standing on it. For a breath, the floor holds its victim the way old tunnels hold their dead \u2014 completely."
    },
    {
      "id": "skill_000659",
      "name": "Pickfall Seam Pressure",
      "role": "damage_over_time",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "totem",
      "energy_cost": 24.4,
      "cooldown_seconds": 5.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.1
          }
        }
      ],
      "flavor_text": "The floor remembers every strike that ever split it open. Water finds the old wounds and holds them there, trembling, until nothing beneath can move."
    },
    {
      "id": "skill_000660",
      "name": "Seam Ring Ignition",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 19.9,
      "cooldown_seconds": 7.5,
      "damage_multiplier": 0.8556,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        },
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 4.8
          }
        }
      ],
      "flavor_text": "Pressure builds where the old coal veins remember fire, and the ring erupts outward in a slow, suffocating bloom of heat that clings like soot to wet stone. What burns here does not flash \u2014 it settles, patient as the dark behind a sealed shaft door."
    }
  ],
