  "skills": [
    {
      "id": "skill_000918",
      "name": "Pickfall Load Bearing",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "melee_strike",
      "energy_cost": 9.0,
      "cooldown_seconds": 0.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 4.0
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.07
          }
        }
      ],
      "flavor_text": "The blow lands where the old dwarves once braced everything \u2014 a pressure point the stone still remembers, locking flesh and floor alike in sudden, breathless arrest. What the halls could not hold, the strike reclaims."
    },
    {
      "id": "skill_000919",
      "name": "Load-Bearing Stillness",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "self_buff",
      "energy_cost": 23.6,
      "cooldown_seconds": 13.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.8
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.33,
            "duration_seconds": 9.0
          }
        }
      ],
      "flavor_text": "The obsidian holds what the mountain forgot how to hold \u2014 pressure absorbed into silence, each crack sealed by the memory of weight. Nothing passes through what has already decided to remain."
    },
    {
      "id": "skill_000920",
      "name": "Pickfall Remembrance",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "ground_slam",
      "energy_cost": 21.3,
      "cooldown_seconds": 4.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The obsidian floor remembers every hammer that ever fell here. It gives that memory back all at once."
    },
    {
      "id": "skill_000921",
      "name": "Pickfall Seam Pressure",
      "role": "control",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "vortex_pull",
      "energy_cost": 27.5,
      "cooldown_seconds": 10.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.0
          }
        }
      ],
      "flavor_text": "The ground remembers every strike ever driven into it, and for a moment it refuses to let go. Pressure wells up through the stone like water finding its level, pinning what stands above it in place."
    },
    {
      "id": "skill_000922",
      "name": "Pickfall Spiral",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "ground_slam",
      "energy_cost": 26.2,
      "cooldown_seconds": 4.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "Where the old shafts meet silence, the stone remembers every blow dealt to it. A vortex of fractured obsidian and tunnel-dark pressure tears outward from a single still point, as though the mountain itself exhales a century of grievances."
    },
    {
      "id": "skill_000924",
      "name": "Shaft Echo Seam",
      "role": "utility",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "circle",
      "energy_cost": 18.0,
      "cooldown_seconds": 17.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.26,
            "duration_seconds": 5.6
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.0
          }
        }
      ],
      "flavor_text": "A pressure ring blooms outward through the stone-wet dark, swallowing sound whole before it can find a wall to answer. What remains is a ringing absence, and the weight of a blow that has nowhere left to go but forward."
    },
    {
      "id": "skill_000925",
      "name": "Still Water Mending",
      "role": "sustain",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "single_target",
      "energy_cost": 34.1,
      "cooldown_seconds": 7.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        }
      ],
      "flavor_text": "Where the old forges have gone cold and silent, water finds the cracks and fills them \u2014 not with force, but with patient, heavy presence. The wound closes like a flooded shaft, dark and complete."
    }
  ],
