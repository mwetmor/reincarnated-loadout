  "skills": [
    {
      "id": "skill_000661",
      "name": "Shaft Echo Pull",
      "role": "control",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 16.4,
      "cooldown_seconds": 17.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shock",
          "params": {
            "duration_seconds": 1.6
          }
        }
      ],
      "flavor_text": "Water finds the old tunnels first, rushing through forgotten shafts in a spiral that drags everything toward the dark center. For a breath, the walls remember the sound of picks \u2014 and everything standing nearby forgets how to stand."
    },
    {
      "id": "skill_000662",
      "name": "Shaft Echo Ring",
      "role": "control",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 21.5,
      "cooldown_seconds": 15.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shock",
          "params": {
            "duration_seconds": 1.7
          }
        }
      ],
      "flavor_text": "Water finds the old drill-holes first, pooling in rings where the stone remembers pressure. The vibration travels outward through flooded corridors, locking limbs in a tremor the rock has held for centuries."
    },
    {
      "id": "skill_000663",
      "name": "Shaft Echo Slip",
      "role": "mobility",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "teleport",
      "energy_cost": 14.7,
      "cooldown_seconds": 7.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.28,
            "duration_seconds": 8.0
          }
        }
      ],
      "flavor_text": "The old tunnels remember every footfall, and the water that weeps through the stone knows how to move without being seen. You borrow that knowledge, sliding through the dark where the sound goes but the body does not."
    },
    {
      "id": "skill_000664",
      "name": "Shaft Echo Rising",
      "role": "utility",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 12.5,
      "cooldown_seconds": 12.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.11,
            "duration_seconds": 6.7
          }
        }
      ],
      "flavor_text": "Deep in the drowned corridors where hammers no longer fall, the silence has learned to carry force. You borrow that pressure \u2014 the memory of ten thousand strikes still ringing in flooded stone."
    },
    {
      "id": "skill_000665",
      "name": "Shaft Echo Surge",
      "role": "area_damage",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "chain_lightning",
      "energy_cost": 26.2,
      "cooldown_seconds": 6.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "lightning"
          }
        }
      ],
      "flavor_text": "A forgotten current finds the old ore veins, leaping shaft to shaft through flooded corridors no living hand has touched. The halls remember the shape of thunder better than they remember warmth."
    },
    {
      "id": "skill_000667",
      "name": "Shaft Echo Surge",
      "role": "mobility",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "teleport",
      "energy_cost": 14.8,
      "cooldown_seconds": 8.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shock",
          "params": {
            "duration_seconds": 1.9
          }
        }
      ],
      "flavor_text": "Water finds the forgotten seams of the rock and moves through them before the stone can object. The shock that follows is the hall remembering what it felt like to be full."
    },
    {
      "id": "skill_000668",
      "name": "Shaft Echo Seep",
      "role": "damage_over_time",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 14.8,
      "cooldown_seconds": 7.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shock",
          "params": {
            "duration_seconds": 1.0
          }
        }
      ],
      "flavor_text": "Water finds the old drill-paths, tracing every forgotten bore with a pressure that hums against stone and bone alike. The halls remember the rhythm of picks, and now that rhythm answers back."
    },
    {
      "id": "skill_000669",
      "name": "Still Shaft Holding",
      "role": "defensive",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 18.2,
      "cooldown_seconds": 8.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 6.5
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.11,
            "duration_seconds": 5.6
          }
        }
      ],
      "flavor_text": "The silence of abandoned tunnels becomes armor, a pressure so complete that blows lose their way in the dark. Water remembers every crack it has ever filled, and fills them again."
    },
    {
      "id": "skill_000670",
      "name": "Brine Ring Settling",
      "role": "control",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "aura",
      "energy_cost": 26.8,
      "cooldown_seconds": 10.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "chill",
          "params": {
            "slow_percent": 0.21,
            "duration_seconds": 4.4
          }
        }
      ],
      "flavor_text": "Salt seeps into the stone's old memory, drawing the air thick and slow around whatever stands within. The halls have waited this long \u2014 a few more moments cost nothing."
    },
    {
      "id": "skill_000672",
      "name": "Brine Load Stillness",
      "role": "defensive",
      "canonical_element": "water",
      "seasonal_element": "brine",
      "geometry_type": "self_buff",
      "energy_cost": 20.1,
      "cooldown_seconds": 12.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.1
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.16,
            "duration_seconds": 6.5
          }
        }
      ],
      "flavor_text": "The salt remembers what stone forgot \u2014 it seeps into every crack and holds. What presses against you finds itself preserved in resistance, bitter and immovable as the halls that outlasted their makers."
    },
    {
      "id": "skill_000673",
      "name": "Shaft Echo Surge",
      "role": "area_damage",
      "canonical_element": "lightning",
      "seasonal_element": null,
      "geometry_type": "chain_lightning",
      "energy_cost": 19.5,
      "cooldown_seconds": 7.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "lightning"
          }
        },
        {
          "name": "shock",
          "params": {
            "duration_seconds": 0.8
          }
        }
      ],
      "flavor_text": "Deep in the drowned corridors, the water remembers every hammer strike and screams it back at once. The vortex pulls inward before the lightning answers, and the stone walls ring like a bell no dwarf will ever hear again."
    }
