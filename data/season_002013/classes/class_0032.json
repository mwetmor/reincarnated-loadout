{
  "id": "class_0032",
  "name": "Collapsed Surveyor",
  "title_completion": "a Collapsed Surveyor",
  "flavor_text": "She once mapped the deep veins of the earth, charting every shaft and seam before the halls fell silent and the brine crept in. Now she reads the echoes that bounce through flooded tunnels, coaxing sound into walls of crackling pressure that pin enemies against wet obsidian. The dwarves are gone, but the geometry of their ruin still obeys her.",
  "archetype_tag": "lightning_controller",
  "energy_type": "mana",
  "role_orientation": "control",
  "range_profile": "medium",
  "dominant_element": "lightning",
  "seasonal_dominant_element": null,
  "is_act_boss": false,
