  "skills": [
    {
      "id": "skill_000794",
      "name": "Withdrawal Soot Seam",
      "role": "primary_attack",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "multi_projectile",
      "energy_cost": 6.7,
      "cooldown_seconds": 0.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "Where the old forges went cold, shadow pooled in the cracks like standing water \u2014 and learned to move. It finds the gaps between stone and memory, splitting outward in dark rivulets that carry the weight of everything abandoned."
    },
    {
      "id": "skill_000795",
      "name": "Withdrawal Soot Ring",
      "role": "control",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 16.9,
      "cooldown_seconds": 11.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.5
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "A hush spreads outward through the drowned dark of empty tunnels, swallowing sound before it can find a wall to answer. The shadow settles like soot on still water, and nothing speaks."
    },
    {
      "id": "skill_000796",
      "name": "Withdrawal Soot Drain",
      "role": "control",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "ring",
      "energy_cost": 28.9,
      "cooldown_seconds": 18.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "silence",
          "params": {
            "duration_seconds": 3.1
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 0,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "The silence of abandoned shafts pulls inward like a held breath, dragging sound and shadow into the dark where no hammer has rung for generations. What it takes, it does not return."
    },
    {
      "id": "skill_000797",
      "name": "Withdrawal Soot Seam",
      "role": "damage_over_time",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 12.6,
      "cooldown_seconds": 4.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "drain",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 8.5
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "shadow"
          }
        }
      ],
      "flavor_text": "Where the forges went cold, something darker learned to breathe \u2014 it seeps through the stone in rings, pulling warmth from bone the way water pulls salt from dead rock. The halls do not echo here; they only take."
    },
    {
      "id": "skill_000798",
      "name": "Withdrawal Soot Reading",
      "role": "utility",
      "canonical_element": "shadow",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 11.5,
      "cooldown_seconds": 14.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.31,
            "duration_seconds": 4.4
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 2.7
          }
        }
      ],
      "flavor_text": "In the breathless dark where the forges went cold, a dwarven hand once pressed flat against the wall and listened before speaking. The silence that follows is not empty \u2014 it is loaded."
    }
