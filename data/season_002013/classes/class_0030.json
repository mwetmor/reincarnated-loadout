{
  "id": "class_0030",
  "name": "Collapsed Shaft Warden",
  "title_completion": "a Collapsed Shaft Warden",
  "flavor_text": "The halls are empty now, but the stone remembers every pick-strike, every breath, every cave-in swallowed in silence. You do not fight with fire or fury \u2014 you fight with weight, with the patient inevitability of a ceiling that has decided it is done holding. Let them step into your ground, and let the mountain answer.",
  "archetype_tag": "earth_controller",
  "energy_type": "mana",
  "role_orientation": "control",
  "range_profile": "medium",
  "dominant_element": "earth",
  "seasonal_dominant_element": "obsidian",
  "is_act_boss": false,
