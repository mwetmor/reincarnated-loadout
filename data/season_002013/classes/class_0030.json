  "skills": [
    {
      "id": "skill_000634",
      "name": "Shaft Echo Collapse",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 20.2,
      "cooldown_seconds": 7.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "The old tunnels remember every blow ever struck within them. Pressure rings outward through stone and silence, and the walls answer back."
    },
    {
      "id": "skill_000636",
      "name": "Shaft Echo Stillness",
      "role": "control",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "vortex_pull",
      "energy_cost": 20.7,
      "cooldown_seconds": 8.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 16.7
          }
        }
      ],
      "flavor_text": "The flooded tunnels remember every footfall, and the water holds them in place the way stone once held ore. Something beneath the surface refuses to let go."
    },
    {
      "id": "skill_000637",
      "name": "Pickfall Ring",
      "role": "area_damage",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 28.8,
      "cooldown_seconds": 7.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "earth"
          }
        },
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.5
          }
        }
      ],
      "flavor_text": "The floor remembers every blow it ever took. One breath of Load-Bearing Stillness and the old fractures speak all at once, locking everything in the radius beneath a crown of upthrust obsidian shards."
    },
    {
      "id": "skill_000639",
      "name": "Load-Bearing Stillness",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "self_buff",
      "energy_cost": 18.1,
      "cooldown_seconds": 10.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.6
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.32,
            "duration_seconds": 7.3
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.16,
            "duration_seconds": 4.8
          }
        }
      ],
      "flavor_text": "The old obsidian walls remember every weight they ever held \u2014 press your back against that memory and nothing moves you. Water finds every crack, but not this one, not now."
    },
    {
      "id": "skill_000640",
      "name": "Pickfall Ring",
      "role": "control",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "vortex_pull",
      "energy_cost": 17.0,
      "cooldown_seconds": 14.6,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.0
          }
        }
      ],
      "flavor_text": "Where the shafts went silent, the stone remembers every footfall \u2014 a circle of arrested weight presses down through flooded corridors, holding fast whatever dares to move within it. The water does not rush here; it simply refuses to release."
    },
    {
      "id": "skill_000641",
      "name": "Collapse Draft Step",
      "role": "mobility",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "dash_attack",
      "energy_cost": 17.5,
      "cooldown_seconds": 10.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 3.0
          }
        }
      ],
      "flavor_text": "The dwarf-carved air still remembers where the walls once stood, and something ancient seizes your feet the moment you arrive. You are here, rooted, held by the hollow pressure of what collapsed long before you."
    },
    {
      "id": "skill_000642",
      "name": "Seam Pressure Break",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 26.6,
      "cooldown_seconds": 7.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Where the old coal veins ran deepest, the earth still holds its heat \u2014 and sometimes, it lets go all at once. The ground splits open in a ring of compressed fire, exhaling centuries of smoldering patience in a single, terrible breath."
    },
    {
      "id": "skill_000643",
      "name": "Pickfall Ring Holds",
      "role": "control",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "vortex_pull",
      "energy_cost": 19.9,
      "cooldown_seconds": 13.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.1
          }
        }
      ],
      "flavor_text": "Where the obsidian seam fractured and the hall went silent, something in the stone remembers how to refuse movement. The ring settles like water finding the lowest crack, and nothing caught within it walks free."
    },
    {
      "id": "skill_000644",
      "name": "Seam Pressure Bloom",
      "role": "damage_over_time",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 19.8,
      "cooldown_seconds": 4.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "burn",
          "params": {
            "tick_damage": 750,
            "duration_seconds": 3.7
          }
        }
      ],
      "flavor_text": "Where the dwarves once split stone with patient fire, the ground remembers. Heat rises slow through flooded tunnels, finding every crack."
    },
    {
      "id": "skill_000645",
      "name": "Collapse Draft Reflex",
      "role": "mobility",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "teleport",
      "energy_cost": 17.8,
      "cooldown_seconds": 9.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.17,
            "duration_seconds": 5.7
          }
        }
      ],
      "flavor_text": "The body learns what the mines taught: when the air shifts, you move before the ceiling does. For a breath, you are nothing the stone can catch."
    },
    {
      "id": "skill_000646",
      "name": "Shaft Echo Seam",
      "role": "control",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "vortex_pull",
      "energy_cost": 25.9,
      "cooldown_seconds": 18.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "root",
          "params": {
            "duration_seconds": 2.2
          }
        }
      ],
      "flavor_text": "A ring of pressurized dark water erupts from the flooded tunnel floor, locking boots to stone the way forgotten halls hold their silence. The obsidian veins in the rock hum with it, remembering every footstep that once belonged here."
    }
  ],
