{
  "id": "class_0035",
  "name": "Shaft Diver",
  "title_completion": "a Shaft Diver",
  "flavor_text": "Where the dwarves once swung their picks in thunderous rhythm, you have learned to read the silence they left behind \u2014 the groan of unsupported stone, the draft that whispers before a tunnel breathes its last. You do not fight so much as fall with precision, letting gravity and the memory of old seams carry your strikes deeper than muscle alone could manage. The empty halls remember the shape of industry, and you move through them like a rumor of what once echoed here.",
  "archetype_tag": "hunter",
  "energy_type": "focus",
  "role_orientation": "damage",
  "range_profile": "long",
  "dominant_element": "physical",
  "seasonal_dominant_element": null,
