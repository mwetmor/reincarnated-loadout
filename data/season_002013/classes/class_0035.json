  "skills": [
    {
      "id": "skill_000799",
      "name": "Pickfall Seam Drop",
      "role": "mobility",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "leap_strike",
      "energy_cost": 12.7,
      "cooldown_seconds": 10.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "bleed",
          "params": {
            "tick_damage": 1009,
            "duration_seconds": 4.8
          }
        }
      ],
      "flavor_text": "The dwarf who knows these halls doesn't run \u2014 he falls sideways through the dark, arriving where the stone remembers being struck. The wound opens after, slow as a seam filling with water."
    },
    {
      "id": "skill_000800",
      "name": "Pickfall Seam Pressure",
      "role": "burst_damage",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "melee_arc",
      "energy_cost": 25.6,
      "cooldown_seconds": 7.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 3364,
            "element": "physical",
            "pierce": 1,
            "multishot": 2
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.08
          }
        }
      ],
      "flavor_text": "Where the old shafts gave way, the water found its path \u2014 straight down, without mercy. A single point of contact, and the hollow dark remembers every blow it ever swallowed."
    },
    {
      "id": "skill_000801",
      "name": "Pickfall Brace",
      "role": "defensive",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 15.9,
      "cooldown_seconds": 12.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1346,
            "duration_seconds": 4.0
          }
        }
      ],
      "flavor_text": "The stone remembers every blow it has ever absorbed. For a moment, so do you."
    },
    {
      "id": "skill_000802",
      "name": "Pickfall Seam Drift",
      "role": "mobility",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "dash_attack",
      "energy_cost": 13.6,
      "cooldown_seconds": 6.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "bleed",
          "params": {
            "tick_damage": 1009,
            "duration_seconds": 3.5
          }
        }
      ],
      "flavor_text": "The dwarf vanishes into a crack in the stone where water once ran, reappearing where the rock remembers the weight of old tools. Something tears open in the passing \u2014 a wound that weeps slow and steady, like a forgotten seam giving way."
    },
    {
      "id": "skill_000803",
      "name": "Pickfall Stillness",
      "role": "defensive",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 18.6,
      "cooldown_seconds": 9.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1346,
            "duration_seconds": 7.8
          }
        }
      ],
      "flavor_text": "Where the last hammer rang and the tunnels went quiet, something dense and unyielding answers the blow. Water finds the cracks the dwarves left behind, and holds them shut."
    },
    {
      "id": "skill_000804",
      "name": "Collapse Draft Scatter",
      "role": "area_damage",
      "canonical_element": "wind",
      "seasonal_element": "pall",
      "geometry_type": "vortex_pull",
      "energy_cost": 29.2,
      "cooldown_seconds": 3.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2018,
            "element": "wind"
          }
        }
      ],
      "flavor_text": "Where the dwarves once breathed, the air still remembers how to rush through broken corridors. It does not wait for permission."
    },
    {
      "id": "skill_000805",
      "name": "Pickfall Load-Bearing Stillness",
      "role": "defensive",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 19.9,
      "cooldown_seconds": 10.7,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1346,
            "duration_seconds": 6.1
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.2,
            "duration_seconds": 6.8
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.22,
            "duration_seconds": 6.6
          }
        }
      ],
      "flavor_text": "Where the tunnels gave way and the water came in, something in the stone learned to hold. The weight settles into you like a flooded shaft going quiet."
    },
    {
      "id": "skill_000807",
      "name": "Pickfall Seam Pressure",
      "role": "primary_attack",
      "canonical_element": "physical",
      "seasonal_element": null,
      "geometry_type": "melee_strike",
      "energy_cost": 8.14,
