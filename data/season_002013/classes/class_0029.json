{
  "id": "class_0029",
  "name": "Brine-Soaked Delver",
  "title_completion": "a Brine-Soaked Delver",
  "flavor_text": "The halls are empty now, but the walls still remember the weight of ten thousand picks. You read the pressure in the stone the way others read scripture — feeling where the seams will hold and where they will not, coaxing salt-heavy magic from the dark between coal veins. The dwarves left. The shafts did not.",
  "archetype_tag": "hybrid_mage",
  "energy_type": "mana",
  "role_orientation": "hybrid",
  "range_profile": "medium",
  "dominant_element": "water",
  "seasonal_dominant_element": "brine",
