  "skills": [
    {
      "id": "skill_000609",
      "name": "Withdrawal Soot Surge",
      "role": "utility",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "circle",
      "energy_cost": 11.2,
      "cooldown_seconds": 19.5,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_damage",
          "params": {
            "percent": 0.31,
            "duration_seconds": 5.0
          }
        },
        {
          "name": "silence",
          "params": {
            "duration_seconds": 1.7
          }
        }
      ],
      "flavor_text": "The silence of emptied halls fills your lungs like cold ash, and for a breath the world holds its voice. What strikes from that stillness carries the weight of everything the stone once knew."
    },
    {
      "id": "skill_000610",
      "name": "Load-Bearing Stillness",
      "role": "defensive",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "self_buff",
      "energy_cost": 23.1,
      "cooldown_seconds": 13.2,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 4.2
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.26,
            "duration_seconds": 5.4
          }
        }
      ],
      "flavor_text": "The dwarf who refused to flee stands yet in the deep dark, unmoved by flood or ruin, and something of that refusal seeps into the bones. Water breaks against you the way it broke against the last pillar — finding nothing to take."
    },
    {
      "id": "skill_000611",
      "name": "Pickfall Shaft Echo",
      "role": "burst_damage",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "single_target",
      "energy_cost": 27.4,
      "cooldown_seconds": 9.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "earth"
          }
        }
      ],
      "flavor_text": "A charged stillness gathers in the drowned tunnels before the earth remembers how to strike. The crack leaps vein to vein through flooded stone, each seam giving way in sequence like a hall that has held its breath too long."
    },
    {
      "id": "skill_000612",
      "name": "Load-Bearing Stillness",
      "role": "defensive",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "self_buff",
      "energy_cost": 22.9,
      "cooldown_seconds": 13.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 5.2
          }
        },
        {
          "name": "buff_defense",
          "params": {
            "percent": 0.16,
            "duration_seconds": 8.1
          }
        },
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.17,
            "duration_seconds": 8.4
          }
        }
      ],
      "flavor_text": "Where the old columns stood, something in the flooded dark still holds. The obsidian remembers the weight it was cut to bear, and for a breath, so do you."
    },
    {
      "id": "skill_000613",
      "name": "Damp Creep Mending",
      "role": "sustain",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "single_target",
      "energy_cost": 28.5,
      "cooldown_seconds": 10.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "heal",
          "params": {
            "magnitude": 1250
          }
        },
        {
          "name": "heal_over_time",
          "params": {
            "tick_heal": 375,
            "duration_seconds": 9.2
          }
        },
        {
          "name": "buff_mana_regen",
          "params": {
            "percent": 0.23,
            "duration_seconds": 7.4
          }
        }
      ],
      "flavor_text": "Water finds every crack the dwarves left behind, pooling slow and deliberate in the dark where the forges went cold. It does not rush — it saturates, filling the wounded with a seeping patience older than the stone itself."
    },
    {
      "id": "skill_000614",
      "name": "Collapse Draft Roll",
      "role": "mobility",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "self_buff",
      "energy_cost": 14.0,
      "cooldown_seconds": 12.0,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "buff_dodge",
          "params": {
            "percent": 0.19,
            "duration_seconds": 9.9
          }
        }
      ],
      "flavor_text": "The empty halls breathe out when no one expects it, a sudden displacement of stale air that carries the wise dwarf sideways before the stone even settles. Nine heartbeats of borrowed momentum, drawn from the memory of what once moved through these corridors."
    },
    {
      "id": "skill_000616",
      "name": "Seam Pressure Pickfall",
      "role": "burst_damage",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "single_target",
      "energy_cost": 33.4,
      "cooldown_seconds": 6.9,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Somewhere beneath the waterlogged silence, the coal remembers compression — and releases it all at once, jumping seam to seam through the dark like the halls themselves are coughing fire. The damp stone carries the chain long after the dwarves stopped listening."
    },
    {
      "id": "skill_000618",
      "name": "Pickfall Seam",
      "role": "primary_attack",
      "canonical_element": "earth",
      "seasonal_element": "obsidian",
      "geometry_type": "multi_projectile",
      "energy_cost": 8.9,
      "cooldown_seconds": 0.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "earth"
          }
        },
        {
          "name": "lifesteal",
          "params": {
            "percent": 0.09
          }
        }
      ],
      "flavor_text": "The blow lands where the stone remembers being struck before, reopening old wounds in the rock and in the self. Something returns through the crack — slow, mineral, sustaining."
    },
    {
      "id": "skill_000621",
      "name": "Seam Pressure Ring",
      "role": "area_damage",
      "canonical_element": "fire",
      "seasonal_element": "coal",
      "geometry_type": "ground_targeted_circle",
      "energy_cost": 19.2,
      "cooldown_seconds": 3.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "fire"
          }
        }
      ],
      "flavor_text": "Where dwarven boots once wore grooves into stone, heat remembers the weight of industry. A compressed ring of fire erupts outward from the seam, as if the halls themselves exhale one last breath of the forge."
    }
  ],
