  "skills": [
    {
      "id": "skill_000727",
      "name": "Forge Remembrance Strike",
      "role": "primary_attack",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "melee_strike",
      "energy_cost": 6.3,
      "cooldown_seconds": 0.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 625,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "Where the hammers have long gone silent, the stone still holds their heat \u2014 each blow lands with the sacred weight of ten thousand forgotten shifts. The light that rises from the impact is not fire, but memory made holy."
    },
    {
      "id": "skill_000728",
      "name": "Forge Remembrance Seam",
      "role": "burst_damage",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "single_target",
      "energy_cost": 38.1,
      "cooldown_seconds": 9.4,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 2500,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "Deep in the drowned corridors where dwarven forges long went cold, something holy still pressurizes the dark \u2014 waiting for a mind wise enough to crack the seam open. The light that floods out does not illuminate. It judges."
    },
    {
      "id": "skill_000729",
      "name": "Forge Remembrance Breaks",
      "role": "area_damage",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "ground_slam",
      "energy_cost": 17.5,
      "cooldown_seconds": 4.3,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "damage",
          "params": {
            "magnitude": 1500,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "The floor remembers every hammer, every prayer, every dwarf who stood here and believed the stone would hold. It does not hold now."
    },
    {
      "id": "skill_000730",
      "name": "Forge Remembrance Seam",
      "role": "damage_over_time",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "circle",
      "energy_cost": 20.2,
      "cooldown_seconds": 6.1,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "consecrate",
          "params": {
            "zone_duration_seconds": 4.0,
            "dot_tick_damage": 750,
            "heal_amplification_percent": 0.13
          }
        },
        {
          "name": "damage",
          "params": {
            "magnitude": 750,
            "element": "holy"
          }
        }
      ],
      "flavor_text": "Where the hammer last fell, the stone still holds its heat \u2014 a sacred pressure that bleeds upward through water-dark rock, searing what walks above it. The halls remember every strike, and they do not forgive trespass."
    },
    {
      "id": "skill_000731",
      "name": "Load-Bearing Stillness",
      "role": "defensive",
      "canonical_element": "holy",
      "seasonal_element": null,
      "geometry_type": "self_buff",
      "energy_cost": 18.1,
      "cooldown_seconds": 11.8,
      "damage_multiplier": 1.0,
      "effects": [
        {
          "name": "shield",
          "params": {
            "magnitude": 1000,
            "duration_seconds": 7.1
          }
        }
      ],
      "flavor_text": "Where the old supports still hold, something remembers how to bear weight \u2014 the damp air presses in, but does not pass. A quiet that has outlasted the hammers settles around you like stone that has never once considered falling."
    }
  ],
